<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SampleApp.ViewModels"
        xmlns:sampleApp="clr-namespace:SampleApp"
        xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
        xmlns:demoPages="clr-namespace:SampleApp.DemoPages"
        xmlns:experiments="clr-namespace:SampleApp.Experiments"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="450"
        WindowState="Maximized"
        x:Class="SampleApp.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Devolutions Theme Sampler">

  <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
    <!-- Canvas wrapper sized for the scaled content so ScrollViewer knows bounds -->
    <Canvas Name="ScaledWrapper">
      <!-- Content container that gets scaled -->
      <Border Name="ScaledContainer">
        <Panel>
          <Panel Name="PreviewWallpaper" IsVisible="{Binding Source={x:Static sampleApp:App.IsWallpaperPreviewTheme}, Mode=OneTime}" />
          <Panel Name="MainContentPanel" Classes="mainControl">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
              <Border Grid.Column="0" Margin="8 8 0 8" BorderBrush="Gray" BorderThickness="0,0,1,0">
                <TreeView x:Name="MainNavigationTree"
                          Margin="0 0 8 0"
                          SelectionChanged="NavigationTree_OnSelectionChanged">
                  <TreeView.Styles>
                    <Style Selector="TreeViewItem">
                      <Setter Property="IsExpanded" Value="{ReflectionBinding IsExpanded, Mode=TwoWay}" />
                    </Style>
                  </TreeView.Styles>
                  <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{ReflectionBinding Children}">
                      <ContentPresenter Content="{ReflectionBinding Header}" HorizontalAlignment="Stretch" />
                    </TreeDataTemplate>
                  </TreeView.ItemTemplate>
                </TreeView>
              </Border>

              <Border Grid.Column="1" Margin="0 8 8 8">
                <ContentControl x:Name="MainPageHost" />
              </Border>
            </Grid>

            <Border HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Width="400"
                    Padding="0 0 8 8">
               <actipro:ShadowChrome Elevation="8" ShadowColor="Black" ShadowOpacity="0.7">
                 <Border Background="{DynamicResource BackgroundColor}"
                         CornerRadius="5"
                         BorderThickness="1"
                         BorderBrush="Gray"
                         Padding="5">
                   <StackPanel>
                     <TextBlock Text="{Binding SystemScale, StringFormat='Default System scale: {0:P0}'}"
                                FontSize="11"
                                Opacity="0.7"
                                Margin="2 0 0 4" />
                     <Grid ColumnDefinitions="Auto,5,*,5,Auto">
                       <!-- ~1~ Scale Selector @1@ -->
                       <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                         <TextBlock Text="Scale:"
                                    VerticalAlignment="Center"
                                    Margin="0 0 5 0" />
                         <ComboBox Width="100"
                                   MaxDropDownHeight="500"
                                   VerticalAlignment="Center"
                                   ItemsSource="{Binding AvailableScales}"
                                   SelectedItem="{Binding SelectedScale}"
                                   SelectionChanged="Scale_OnSelectionChanged" />
                       </StackPanel>
              
                       <!-- ~1~ Theme Selector @1@ -->
                       <ComboBox x:Name="Themes"
                                 Grid.Column="2"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Center"
                                 DisplayMemberBinding="{Binding DisplayName, x:DataType=sampleApp:Theme}"
                                 ItemsSource="{Binding AvailableThemes}"
                                 SelectedItem="{Binding CurrentTheme}"
                                 SelectionChanged="Themes_OnSelectionChanged" />
              
                       <!-- ~1~ Dark/Light Toggle @1@ -->
                       <actipro:ToggleThemeButton
                         Grid.Column="4"
                         Classes.theme-outline="True"
                         VerticalAlignment="Center" />
                     </Grid>
                   </StackPanel>
                 </Border>
               </actipro:ShadowChrome>
            </Border>

            <Border HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Width="250"
                    Padding="0 8 8 0"
                    IsVisible="{Binding Source={x:Static sampleApp:App.IsWallpaperPreviewTheme}, Mode=OneTime}">
              <actipro:ShadowChrome Elevation="8" ShadowColor="Black" ShadowOpacity="0.7">
                 <Border Background="{DynamicResource BackgroundColor}"
                         CornerRadius="5"
                         BorderThickness="1"
                         BorderBrush="Gray"
                         Padding="5">
                   <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                     <TextBlock Text="Wallpaper:" VerticalAlignment="Center" Margin="0 0 10 0" />
                     <ComboBox ItemsSource="{Binding AvailableWallpapers}"
                               SelectedItem="{Binding SelectedWallpaper}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Stretch"
                               MinWidth="100" />
                   </StackPanel>
                 </Border>
               </actipro:ShadowChrome>
            </Border>
          </Panel>
        </Panel>
      </Border>
    </Canvas>
  </ScrollViewer>

</Window>
