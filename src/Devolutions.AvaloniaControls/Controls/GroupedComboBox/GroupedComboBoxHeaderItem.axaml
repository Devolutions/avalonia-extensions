<ResourceDictionary
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ControlTheme x:Key="{x:Type GroupedComboBoxHeaderItem}" TargetType="GroupedComboBoxHeaderItem">
    <Setter Property="HeaderForeground" Value="{DynamicResource SystemControlForegroundAccentBrush}" />
    <Setter Property="Template">
      <ControlTemplate>
        <!-- <TextBlock Text="{TemplateBinding HeaderText}" -->
        <!--            Foreground="{TemplateBinding HeaderForeground}" -->
        <!--            FontWeight="SemiBold" -->
        <!--            Margin="{TemplateBinding HeaderMargin}" /> -->
        <ContentPresenter
          Name="PART_ContentPresenter"
          Content="{TemplateBinding Content}"
          ContentTemplate="{TemplateBinding ContentTemplate}"
          Margin="{TemplateBinding HeaderMargin}"
          Foreground="{TemplateBinding HeaderForeground}"
          FontWeight="SemiBold"
        />
      </ControlTemplate>
    </Setter>
  </ControlTheme>

</ResourceDictionary>
