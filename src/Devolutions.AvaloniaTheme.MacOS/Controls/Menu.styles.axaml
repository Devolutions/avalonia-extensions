<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:design="clr-namespace:Devolutions.AvaloniaTheme.MacOS.Design">

  <Design.PreviewWith>
    <design:ThemePreviewer>
      <StackPanel Orientation="Vertical" Margin="10">
        <TextBlock Text="Some text" />
        <Separator />
        <TextBlock Text="Separated by a separator" />
      </StackPanel>
    </design:ThemePreviewer>
  </Design.PreviewWith>

  <Style Selector="Menu > Separator, Menu > MenuItem:separator > Separator">
    <Setter Property="Margin" Value="6 4 3 2" />
    <Setter Property="Width" Value="1" />
    <Setter Property="Height" Value="NaN" />
  
    <Style Selector="^ > Border">
      <Setter Property="Width" Value="NaN" />
      <Setter Property="Height" Value="NaN" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>
  </Style>

  <Style Selector="MenuFlyoutPresenter > MenuItem:separator, ContextMenu > MenuItem:separator">
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0" />
  </Style>
</Styles>
