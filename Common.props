<Project>
    <PropertyGroup>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
    </PropertyGroup>

    <PropertyGroup>
        <DemoFramework>net10.0</DemoFramework>
        <LibFrameworks>net10.0;net9.0</LibFrameworks>
        
        <AvaloniaVersion>12.0.0-rc2</AvaloniaVersion>
        <MinimumAvaloniaVersion>[12.0.0-rc2,)</MinimumAvaloniaVersion>
        
        <AvaloniaTreeDataGridVersion>12.0.0-beta1</AvaloniaTreeDataGridVersion>
        <MinimumAvaloniaTreeDataGridVersion>[12.0.0-beta1,)</MinimumAvaloniaTreeDataGridVersion>
    </PropertyGroup>
</Project>