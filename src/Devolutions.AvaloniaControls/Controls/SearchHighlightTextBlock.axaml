<ResourceDictionary
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Design.PreviewWith>
    <SearchHighlightTextBlock
      Search="t wi"
      Content="Test with some stuff" />
  </Design.PreviewWith>

  <ControlTheme x:Key="{x:Type SearchHighlightTextBlock}" TargetType="SearchHighlightTextBlock">
    <Setter Property="HighlightBackground" Value="#66FFFF00" />
    <Setter Property="HighlightForeground" Value="{DynamicResource TextControlButtonForeground}" />
    <Setter Property="Template">
      <ControlTemplate>
        <TextBlock Name="PART_TextBlock" TextTrimming="CharacterEllipsis" />
      </ControlTemplate>
    </Setter>
  </ControlTheme>
</ResourceDictionary>
