<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SampleApp.ViewModels"
        xmlns:sampleApp="clr-namespace:SampleApp"
        xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
        xmlns:demoPages="clr-namespace:SampleApp.DemoPages"
        xmlns:experiments="clr-namespace:SampleApp.Experiments"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="450"
        WindowState="Maximized"
        x:Class="SampleApp.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Devolutions Theme Sampler">

  <!-- TODO: move the margins into the theme ?? -->
  <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
    <!-- Canvas wrapper sized for the scaled content so ScrollViewer knows bounds -->
    <Canvas Name="ScaledWrapper">
      <!-- Content container that gets scaled -->
      <Border Name="ScaledContainer">
        <Panel>
          <Panel Name="PreviewWallpaper" IsVisible="{Binding Source={x:Static sampleApp:App.IsWallpaperPreviewTheme}, Mode=OneTime}" />
          <Panel Name="MainContentPanel" Classes="mainControl">
            <TabControl x:Name="MainTabControl" TabStripPlacement="Left" VerticalAlignment="Stretch">
              <TabItem IsSelected="True">
                <TabItem.Header>
                  <TextBlock FontWeight="600">Overview</TextBlock>
                </TabItem.Header>
                <demoPages:Overview />
              </TabItem>
              <TabItem x:Name="ControlAlignmentTab" Header="✜ Control Alignment">
                <demoPages:ControlAlignment />
              </TabItem>


              <TabItem>
                <TabItem.Header>
                  <StackPanel Orientation="Horizontal">
                    <Svg Path="/Assets/Padlock.svg" Height="16" Width="16" Margin="-2 -2 2 0" Css=".st0 {fill : #3E6CB0; }" />
                    <TextBlock Text="Experiments" />
                  </StackPanel>
                </TabItem.Header>
                <TabControl>
                  <TabItem Header="ActiPro Controls">
                    <experiments:ActiProDemo />
                  </TabItem>
                  <TabItem Header="System Colours">
                    <experiments:SystemColoursDemo />
                  </TabItem>
                  <TabItem Header="Toggle Buttons">
                    <experiments:ToggleButtonExperiments />
                  </TabItem>
                  <TabItem Header="Search Highlights">
                    <experiments:SearchHighlights />
                  </TabItem>
                  <TabItem Header="Animated Icon">
                    <experiments:AnimatedIcon />
                  </TabItem>
                  <TabItem Header="LG Wallpaper Tint">
                    <experiments:LiquidGlassWallpaperTintDemo />
                  </TabItem>
                </TabControl>
              </TabItem>
            </TabControl>

            <Border HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Width="400"
                    Padding="0 0 8 8">
               <actipro:ShadowChrome Elevation="8" ShadowColor="Black" ShadowOpacity="0.7">
                 <Border Background="{DynamicResource BackgroundColor}"
                         CornerRadius="5"
                         BorderThickness="1"
                         BorderBrush="Gray"
                         Padding="5">
                   <StackPanel>
                     <TextBlock Text="{Binding SystemScale, StringFormat='Default System scale: {0:P0}'}"
                                FontSize="11"
                                Opacity="0.7"
                                Margin="2 0 0 4" />
                     <Grid ColumnDefinitions="Auto,5,*,5,Auto">
                       <!-- ~1~ Scale Selector @1@ -->
                       <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                         <TextBlock Text="Scale:"
                                    VerticalAlignment="Center"
                                    Margin="0 0 5 0" />
                         <ComboBox Width="100"
                                   MaxDropDownHeight="500"
                                   VerticalAlignment="Center"
                                   ItemsSource="{Binding AvailableScales}"
                                   SelectedItem="{Binding SelectedScale}"
                                   SelectionChanged="Scale_OnSelectionChanged" />
                       </StackPanel>
              
                       <!-- ~1~ Theme Selector @1@ -->
                       <ComboBox x:Name="Themes"
                                 Grid.Column="2"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Center"
                                 DisplayMemberBinding="{Binding DisplayName, x:DataType=sampleApp:Theme}"
                                 ItemsSource="{Binding AvailableThemes}"
                                 SelectedItem="{Binding CurrentTheme}"
                                 SelectionChanged="Themes_OnSelectionChanged" />
              
                       <!-- ~1~ Dark/Light Toggle @1@ -->
                       <actipro:ToggleThemeButton
                         Grid.Column="4"
                         Classes.theme-outline="True"
                         VerticalAlignment="Center" />
                     </Grid>
                   </StackPanel>
                 </Border>
               </actipro:ShadowChrome>
            </Border>

            <Border HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Width="250"
                    Padding="0 8 8 0"
                    IsVisible="{Binding Source={x:Static sampleApp:App.IsWallpaperPreviewTheme}, Mode=OneTime}">
              <actipro:ShadowChrome Elevation="8" ShadowColor="Black" ShadowOpacity="0.7">
                 <Border Background="{DynamicResource BackgroundColor}"
                         CornerRadius="5"
                         BorderThickness="1"
                         BorderBrush="Gray"
                         Padding="5">
                   <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                     <TextBlock Text="Wallpaper:" VerticalAlignment="Center" Margin="0 0 10 0" />
                     <ComboBox ItemsSource="{Binding AvailableWallpapers}"
                               SelectedItem="{Binding SelectedWallpaper}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Stretch"
                               MinWidth="100" />
                   </StackPanel>
                 </Border>
               </actipro:ShadowChrome>
            </Border>
          </Panel>
        </Panel>
      </Border>
    </Canvas>
  </ScrollViewer>

</Window>
