<ResourceDictionary
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ControlTheme x:Key="{x:Type GroupedTileListBoxItem}" TargetType="GroupedTileListBoxItem" BasedOn="{StaticResource {x:Type GroupedTileListBoxItem}}">
    <!-- Pointer over state -->
    <Style Selector="^:pointerover /template/ Border#PART_Border">
      <Setter Property="Background" Value="{DynamicResource GroupedTileListBoxItemPointerOverBrush}" />
    </Style>

    <!-- Selected state -->
    <Style Selector="^:selected /template/ Border#PART_Border">
      <Setter Property="Background" Value="{DynamicResource GroupedTileListBoxItemPointerOverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
    </Style>
  </ControlTheme>

</ResourceDictionary>