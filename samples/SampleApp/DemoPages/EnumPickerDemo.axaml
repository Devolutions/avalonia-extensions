<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SampleApp.ViewModels"
             xmlns:generic="clr-namespace:System.Collections.Generic;assembly=System.Collections"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SampleApp.DemoPages.EnumPickerDemo"
             x:DataType="vm:EnumPickerViewModel">

  <StackPanel>
    <StackPanel Orientation="Horizontal" Spacing="10" Margin="20 20 20 0">
      <TextBlock VerticalAlignment="Center">For automatic focus test:</TextBlock>
      <EnumPicker x:TypeArguments="vm:DemoPriority" />
    </StackPanel>
    <Border Margin="20" Padding="20" HorizontalAlignment="Left" Background="{DynamicResource LayoutBackgroundLowBrush}">
      <Grid ColumnDefinitions="220 200" RowDefinitions="Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto">
        <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0" Margin="0 0 0 15">
          <Bold>EnumPicker</Bold>
        </TextBlock>

        <TextBlock Grid.Column="0" Grid.Row="1" VerticalAlignment="Center" Margin="0 0 10 5">
          - Default:
        </TextBlock>
        <EnumPicker Grid.Column="1" Grid.Row="1" x:TypeArguments="vm:DemoPriority"
                    SelectedValue="{Binding SelectedDefault}" />
        <TextBlock Grid.Column="1" Grid.Row="2" Margin="0 2 0 10"
                   Text="{Binding SelectedDefault, StringFormat='Selection: {0}'}" />

        <TextBlock Grid.Column="0" Grid.Row="3" VerticalAlignment="Center" Margin="0 0 10 5">
          - Sorted alphabetically:
        </TextBlock>
        <EnumPicker Grid.Column="1" Grid.Row="3" x:TypeArguments="vm:DemoPriority"
                    SortAlphabetically="True"
                    SelectedValue="{Binding SelectedSorted}" />
        <TextBlock Grid.Column="1" Grid.Row="4" Margin="0 2 0 10"
                   Text="{Binding SelectedSorted, StringFormat='Selection: {0}'}" />

        <TextBlock Grid.Column="0" Grid.Row="5" VerticalAlignment="Center" Margin="0 0 10 5">
          - ExcludedValues (no Blocker):
        </TextBlock>
        <EnumPicker Grid.Column="1" Grid.Row="5" x:TypeArguments="vm:DemoPriority"
                    ExcludedValues="{Binding ExcludedValues}"
                    SelectedValue="{Binding SelectedExcluded}" />
        <TextBlock Grid.Column="1" Grid.Row="6" Margin="0 2 0 10"
                   Text="{Binding SelectedExcluded, StringFormat='Selection: {0}'}" />

        <TextBlock Grid.Column="0" Grid.Row="7" VerticalAlignment="Center" Margin="0 0 10 5">
          - IncludedValues (Low/Normal/High):
        </TextBlock>
        <EnumPicker Grid.Column="1" Grid.Row="7" x:TypeArguments="vm:DemoPriority"
                    IncludedValues="{Binding IncludedValues}"
                    SelectedValue="{Binding SelectedIncluded}" />
        <TextBlock Grid.Column="1" Grid.Row="8" Margin="0 2 0 10"
                   Text="{Binding SelectedIncluded, StringFormat='Selection: {0}'}" />

        <TextBlock Grid.Column="0" Grid.Row="9" VerticalAlignment="Center" Margin="0 0 10 5">
          - TextOverrides:
        </TextBlock>
        <EnumPicker Grid.Column="1" Grid.Row="9" x:TypeArguments="vm:DemoPriority"
                    TextOverrides="{Binding TextOverrides}"
                    SelectedValue="{Binding SelectedWithOverrides}" />
        <TextBlock Grid.Column="1" Grid.Row="10" Margin="0 2 0 10"
                   Text="{Binding SelectedWithOverrides, StringFormat='Selection: {0}'}" />

        <TextBlock Grid.Column="0" Grid.Row="11" VerticalAlignment="Center" Margin="0 0 10 5">
          - TextProvider:
        </TextBlock>
        <EnumPicker Grid.Column="1" Grid.Row="11" x:TypeArguments="vm:DemoPriority"
                    TextProvider="{Binding TextProvider}"
                    SelectedValue="{Binding SelectedWithProvider}" />
        <TextBlock Grid.Column="1" Grid.Row="12" Margin="0 2 0 10"
                   Text="{Binding SelectedWithProvider, StringFormat='Selection: {0}'}" />

        <TextBlock Grid.Column="0" Grid.Row="13" VerticalAlignment="Center" Margin="0 0 10 5">
          - Different enum type:
        </TextBlock>
        <EnumPicker Grid.Column="1" Grid.Row="13" x:TypeArguments="vm:DemoStatus"
                    SelectedValue="{Binding SelectedStatus}" />
        <TextBlock Grid.Column="1" Grid.Row="14" Margin="0 2 0 10"
                   Text="{Binding SelectedStatus, StringFormat='Selection: {0}'}" />

        <TextBlock Grid.Column="0" Grid.Row="15" VerticalAlignment="Center" Margin="0 0 10 5">
          - ExcludedValues inline<LineBreak/>(excludes Blocker, Critical):
        </TextBlock>
        <EnumPicker Grid.Column="1" Grid.Row="15" x:TypeArguments="vm:DemoPriority"
                    SelectedValue="{Binding SelectedInlineExcluded}">
          <EnumPicker.ExcludedValues>
            <generic:List x:TypeArguments="vm:DemoPriority">
              <x:Static Member="vm:DemoPriority.Blocker" />
              <x:Static Member="vm:DemoPriority.Critical" />
            </generic:List>
          </EnumPicker.ExcludedValues>
        </EnumPicker>
        <TextBlock Grid.Column="1" Grid.Row="16" Margin="0 2 0 10"
                   Text="{Binding SelectedInlineExcluded, StringFormat='Selection: {0}'}" />

        <TextBlock Grid.Column="0" Grid.Row="17" VerticalAlignment="Center" Margin="0 0 10 5">
          - IncludedValues inline<LineBreak/>(only Low, Normal):
        </TextBlock>
        <EnumPicker Grid.Column="1" Grid.Row="17" x:TypeArguments="vm:DemoPriority"
                    SelectedValue="{Binding SelectedInlineIncluded}">
          <EnumPicker.IncludedValues>
            <generic:List x:TypeArguments="vm:DemoPriority">
              <x:Static Member="vm:DemoPriority.Low" />
              <x:Static Member="vm:DemoPriority.Normal" />
            </generic:List>
          </EnumPicker.IncludedValues>
        </EnumPicker>
        <TextBlock Grid.Column="1" Grid.Row="18" Margin="0 2 0 10"
                   Text="{Binding SelectedInlineIncluded, StringFormat='Selection: {0}'}" />

        <TextBlock Grid.Column="0" Grid.Row="19" VerticalAlignment="Center" Margin="0 0 10 5">
          - TextOverrides inline<LineBreak/>(High → "High !", Critical → "CRITICAL"):
        </TextBlock>
        <EnumPicker Grid.Column="1" Grid.Row="19" x:TypeArguments="vm:DemoPriority"
                    SelectedValue="{Binding SelectedInlineOverrides}">
          <EnumPicker.TextOverrides>
            <EnumPickerTextOverrides x:TypeArguments="vm:DemoPriority">
              <EnumPickerTextOverride x:TypeArguments="vm:DemoPriority" Key="High" Value="High !" />
              <EnumPickerTextOverride x:TypeArguments="vm:DemoPriority" Key="Critical" Value="CRITICAL" />
            </EnumPickerTextOverrides>
          </EnumPicker.TextOverrides>
        </EnumPicker>
        <TextBlock Grid.Column="1" Grid.Row="20" Margin="0 2 0 10"
                   Text="{Binding SelectedInlineOverrides, StringFormat='Selection: {0}'}" />
      </Grid>
    </Border>
  </StackPanel>
</UserControl>
