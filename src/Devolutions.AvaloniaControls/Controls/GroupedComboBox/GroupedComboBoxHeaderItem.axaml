<ResourceDictionary
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ControlTheme x:Key="{x:Type GroupedComboBoxHeaderItem}" TargetType="GroupedComboBoxHeaderItem">
    <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundAccentBrush}" />
    <Setter Property="Margin" Value="4 6  8 4" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </ControlTheme>
</ResourceDictionary>
