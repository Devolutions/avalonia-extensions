<ResourceDictionary
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:Devolutions.AvaloniaControls.Controls;assembly=Devolutions.AvaloniaControls">
  <ControlTheme x:Key="DevExpressTimePickerUpDownTextBoxTheme"
                TargetType="TextBox"
                BasedOn="{StaticResource {x:Type TextBox}}">
    <Setter Property="Foreground" Value="{DynamicResource ForegroundHighBrush}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="FocusAdorner" Value="{x:Null}" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="SelectionForegroundBrush" Value="{DynamicResource TextBoxSelectionForeground}" />
    <Setter Property="CaretBrush" Value="{DynamicResource ForegroundHighBrush}" />
    <Setter Property="Cursor" Value="Ibeam" />
    <Setter Property="TextAlignment" Value="Center" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="ScrollViewer.IsScrollChainingEnabled" Value="True" />
    <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
    <Setter Property="SelectionBrush" Value="{DynamicResource TextSelectionColorSolid}" />
    <Setter Property="Template">
      <ControlTemplate TargetType="TextBox">
        <ScrollViewer
          AllowAutoHide="{TemplateBinding (ScrollViewer.AllowAutoHide)}"
          HorizontalScrollBarVisibility="{TemplateBinding (ScrollViewer.HorizontalScrollBarVisibility)}"
          IsScrollChainingEnabled="{TemplateBinding (ScrollViewer.IsScrollChainingEnabled)}"
          VerticalScrollBarVisibility="{TemplateBinding (ScrollViewer.VerticalScrollBarVisibility)}">
          <TextPresenter
            Name="PART_TextPresenter"
            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
            CaretBrush="{TemplateBinding CaretBrush}"
            CaretIndex="{TemplateBinding CaretIndex}"
            LineHeight="{TemplateBinding LineHeight}"
            PasswordChar="{TemplateBinding PasswordChar}"
            RevealPassword="{TemplateBinding RevealPassword}"
            SelectionBrush="{TemplateBinding SelectionBrush}"
            SelectionEnd="{TemplateBinding SelectionEnd}"
            SelectionForegroundBrush="{TemplateBinding SelectionForegroundBrush}"
            SelectionStart="{TemplateBinding SelectionStart}"
            Text="{TemplateBinding Text, Mode=TwoWay}"
            TextAlignment="{TemplateBinding TextAlignment}"
            TextWrapping="{TemplateBinding TextWrapping}" />
        </ScrollViewer>
      </ControlTemplate>
    </Setter>
  </ControlTheme>

  <ControlTheme x:Key="{x:Type controls:TimePickerUpDown}"
                TargetType="controls:TimePickerUpDown"
                BasedOn="{StaticResource {x:Type controls:TimePickerUpDown}}">
    <Setter Property="Foreground" Value="{DynamicResource ForegroundHighBrush}" />
    <Setter Property="Background" Value="{DynamicResource TextBoxBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TextBoxBorderBrush}" />
    <Setter Property="BorderThickness" Value="1 1 1 0" />
    <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="MinHeight" Value="{DynamicResource TextBasedInputMinHeight}" />
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="FocusAdorner" Value="{x:Null}" />
    <Setter Property="Template">
      <ControlTemplate>
        <DataValidationErrors>
          <Panel>
            <ButtonSpinner Name="PART_Spinner"
                           Background="{TemplateBinding Background}"
                           BorderBrush="{TemplateBinding BorderBrush}"
                           BorderThickness="{TemplateBinding BorderThickness}"
                           CornerRadius="{TemplateBinding CornerRadius}"
                           ButtonSpinnerLocation="{TemplateBinding ButtonSpinnerLocation}"
                           HorizontalContentAlignment="Left"
                           ShowButtonSpinner="{TemplateBinding ShowButtonSpinner}"
                           AllowSpin="{TemplateBinding AllowSpin}"
                           IsTabStop="False"
                           VerticalContentAlignment="Stretch">
              <StackPanel Margin="5,0,15,0"
                          HorizontalAlignment="Left"
                          Orientation="Horizontal"
                          Spacing="0"
                          VerticalAlignment="Center">
                <TextBox Name="PART_HourTextBox"
                         AutomationProperties.Name="Hours"
                         Theme="{StaticResource DevExpressTimePickerUpDownTextBoxTheme}"
                         Classes="segment-box borderless no-focus-border"
                         Foreground="{TemplateBinding Foreground}"
                         IsReadOnly="{TemplateBinding IsReadOnly}"
                         MaxLength="2"
                         Watermark="hh" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{TemplateBinding Foreground}"
                           Text=":" />
                <TextBox Name="PART_MinuteTextBox"
                         AutomationProperties.Name="Minutes"
                         Theme="{StaticResource DevExpressTimePickerUpDownTextBoxTheme}"
                         Classes="segment-box borderless no-focus-border"
                         Foreground="{TemplateBinding Foreground}"
                         IsTabStop="False"
                         IsReadOnly="{TemplateBinding IsReadOnly}"
                         MaxLength="2"
                         Watermark="mm" />
                <TextBlock Name="PART_SecondSeparator"
                           VerticalAlignment="Center"
                           Foreground="{TemplateBinding Foreground}"
                           Text=":" />
                <TextBox Name="PART_SecondTextBox"
                         AutomationProperties.Name="Seconds"
                         Theme="{StaticResource DevExpressTimePickerUpDownTextBoxTheme}"
                         Classes="segment-box borderless no-focus-border"
                         Foreground="{TemplateBinding Foreground}"
                         IsTabStop="False"
                         IsReadOnly="{TemplateBinding IsReadOnly}"
                         MaxLength="2"
                         Watermark="ss" />
                <TextBox Name="PART_PeriodTextBox"
                         AutomationProperties.Name="AM or PM"
                         Theme="{StaticResource DevExpressTimePickerUpDownTextBoxTheme}"
                         Classes="segment-box period-box borderless no-focus-border"
                         Foreground="{TemplateBinding Foreground}"
                         IsTabStop="False"
                         IsReadOnly="{TemplateBinding IsReadOnly}"
                         MaxLength="8"
                         Watermark="AM" />
              </StackPanel>
            </ButtonSpinner>
            <Border Name="BottomBorderElement"
                    Background="Transparent"
                    BorderBrush="{DynamicResource TextBoxBottomBorderBrush}"
                    BorderThickness="0 0 0 1"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    IsHitTestVisible="False" />
            <Border Name="ErrorBorder"
                    BorderBrush="{StaticResource SystemControlErrorTextForegroundBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource ControlCornerRadius}"
                    IsVisible="False" />
          </Panel>
        </DataValidationErrors>
      </ControlTemplate>
    </Setter>

    <Style Selector="^ /template/ TextBox.segment-box">
      <Setter Property="MinWidth" Value="14" />
      <Setter Property="Width" Value="14" />
    </Style>

    <Style Selector="^ /template/ TextBox.period-box">
      <Setter Property="Margin" Value="5,0,0,0" />
      <Setter Property="MinWidth" Value="20" />
      <Setter Property="Width" Value="20" />
    </Style>

    <Style Selector="^:focus-within">
      <Style Selector="^ /template/ Border#BottomBorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderSelectedBrush}" />
        <Setter Property="BorderThickness" Value="0 0 0 1.6" />
      </Style>
    </Style>

    <Style Selector="^ /template/ ButtonSpinner#PART_Spinner RepeatButton">
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="^ /template/ ButtonSpinner#PART_Spinner RepeatButton#PART_IncreaseButton">
      <Setter Property="AutomationProperties.Name" Value="Increase time" />
    </Style>

    <Style Selector="^ /template/ ButtonSpinner#PART_Spinner RepeatButton#PART_DecreaseButton">
      <Setter Property="AutomationProperties.Name" Value="Decrease time" />
    </Style>

    <Style Selector="^:disabled">
      <Style Selector="^ /template/ ButtonSpinner#PART_Spinner">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource TextBoxDisabledBorderSelectedBrush}" />
        <Setter Property="BorderThickness" Value="1" />
      </Style>
      <Style Selector="^ /template/ Border#BottomBorderElement">
        <Setter Property="IsVisible" Value="False" />
      </Style>
    </Style>

    <Style Selector="^:error /template/ Border#ErrorBorder">
      <Setter Property="IsVisible" Value="True" />
    </Style>
  </ControlTheme>
</ResourceDictionary>