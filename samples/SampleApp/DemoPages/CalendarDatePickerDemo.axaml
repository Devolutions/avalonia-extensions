<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:system="clr-namespace:System;assembly=System.Runtime"
             xmlns:viewModels="clr-namespace:SampleApp.ViewModels"
             xmlns:ext="clr-namespace:SampleApp.MarkupExtensions"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SampleApp.DemoPages.CalendarDatePickerDemo"
             x:DataType="viewModels:CalendarDatePickerViewModel">

    <StackPanel>
    <StackPanel Orientation="Horizontal" Spacing="10" Margin="20 20 20 0">
      <TextBlock VerticalAlignment="Center">For automatic focus test:</TextBlock>
      <CalendarDatePicker PlaceholderText=" ">
        <CalendarDatePicker.Styles>
          <Style Selector="TextBox">
            <Setter Property="CaretBrush" Value="Transparent" />
          </Style>
        </CalendarDatePicker.Styles>
      </CalendarDatePicker>
    </StackPanel>
    <Grid ColumnDefinitions="Auto, *, Auto"
          RowDefinitions="Auto, Auto"
          Margin="20"
          ColumnSpacing="30"
          RowSpacing="30">
      <Grid Grid.Column="0" Grid.Row="0"
            ColumnDefinitions="Auto, 250"
            RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto"
            ColumnSpacing="15"
            RowSpacing="14">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Placeholder"   VerticalAlignment="Center" />
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Default"       VerticalAlignment="Center" />
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Disabled"      VerticalAlignment="Center" />
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Long Format"   VerticalAlignment="Center" />
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Custom Format" VerticalAlignment="Center" />
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Reset"         VerticalAlignment="Center" />
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Error"         VerticalAlignment="Center" />

        <CalendarDatePicker Grid.Row="0" Grid.Column="1" HorizontalAlignment="Left" />
        <CalendarDatePicker Grid.Row="1" Grid.Column="1" Name="DatePicker"  HorizontalAlignment="Left" />
        <CalendarDatePicker Grid.Row="2" Grid.Column="1" Name="DatePicker2" HorizontalAlignment="Left" IsEnabled="False" />
        <CalendarDatePicker Grid.Row="3" Grid.Column="1" Name="DatePicker3" HorizontalAlignment="Left" SelectedDateFormat="Long" />
        <CalendarDatePicker Grid.Row="4" Grid.Column="1" Name="DatePicker5" HorizontalAlignment="Left"
                            SelectedDateFormat="Custom" CustomDateFormatString="yyyy'/'MM'/'dd"
                            PlaceholderText="yyyy/MM/dd" />
        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Spacing="10">
          <Button Content="Today" Command="{Binding SetToTodayCommand}" />
          <CalendarDatePicker Name="DatePicker4" HorizontalAlignment="Left" SelectedDate="{Binding SelectedDate}" />
        </StackPanel>
        <CalendarDatePicker Grid.Row="6" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Top">
          <DataValidationErrors.Error>
            <system:Exception>
              <x:Arguments>
                <x:String>Error</x:String>
              </x:Arguments>
            </system:Exception>
          </DataValidationErrors.Error>
        </CalendarDatePicker>
      </Grid>

      <StackPanel Grid.Row="0" Grid.Column="1"
                  Spacing="10" Margin="0">
        <TextBlock TextWrapping="Wrap">
          <TextBlock Classes="code">FirstDayOfWeek</TextBlock> follows system settings, unless explicitly set.<LineBreak /> E.g.
          <TextBlock Classes="code">FirstDayOfWeek="Sunday"</TextBlock>:
        </TextBlock>
        <CalendarDatePicker HorizontalAlignment="Left" FirstDayOfWeek="Sunday" />
      </StackPanel>

      <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="14">
        <TextBlock TextWrapping="Wrap">
          <Bold>Note:</Bold>
          <TextBlock Classes="code">MinWidth</TextBlock> is set to comfortably accommodate short date formats &amp; the corresponding default watermark when
          <TextBlock Classes="code">HorizontalAlignment</TextBlock> is set to anything other than the default (<TextBlock Classes="code">Stretch</TextBlock>).<LineBreak />
          <LineBreak />
          If you set <TextBlock Classes="code">SelectedDateFormat="Long"</TextBlock> you will have to override <TextBlock Classes="code">MinWidth</TextBlock> to the longest
          expected string length, depending on supported languages. Otherwise the control's width will jump when the date is changed.
        </TextBlock>

        <TextBlock TextWrapping="Wrap"
                   IsVisible="{ext:ThemeIsOneOf 'DevExpress, MacClassic, LiquidGlass'}">
          For numeric formats (<TextBlock Classes="code">Short</TextBlock> or a numeric <TextBlock Classes="code">Custom</TextBlock> pattern),
          the text box uses <Bold>segmented input</Bold>: clicking selects the year / month / day section under the cursor,
          ⬅️ /  ➡️ move between sections, ⬆️ /  ⬇️ increment / decrement the active section,
          digits overwrite it, any common separator (<TextBlock Classes="code">/ - . , : space</TextBlock>) advances to the next section, and
          <TextBlock Classes="code">Backspace</TextBlock> resets to the minimum value.
          Long format falls back to free-text editing (no segmentation).<LineBreak />
          <LineBreak />
          <Bold>Note on Custom format strings:</Bold> in .NET, <TextBlock Classes="code">/</TextBlock> and <TextBlock Classes="code">:</TextBlock>
          inside a date format string are replaced with the current culture's date / time separator. To force literal characters, quote them:
          <TextBlock Classes="code">yyyy'/'MM'/'dd</TextBlock>.
        </TextBlock>
      </StackPanel>

      <StackPanel Grid.Row="0" Grid.Column="2"
                  Grid.RowSpan="2"
                  Spacing="20" Margin="30 0 0 0 ">
        <TextBlock Classes="section-title" Text="Blackout Period:" />
        <Calendar DisplayDate="2025-07-25">
          <Calendar.BlackoutDates>
            <CalendarDateRange>
              <x:Arguments>
                <system:DateTime>2023-06-01</system:DateTime>
                <system:DateTime>2025-07-20</system:DateTime>
              </x:Arguments>
            </CalendarDateRange>
          </Calendar.BlackoutDates>
        </Calendar>
      </StackPanel>
    </Grid>
  </StackPanel>
</UserControl>