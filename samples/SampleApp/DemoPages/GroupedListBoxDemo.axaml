<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SampleApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="650"
             x:Class="SampleApp.DemoPages.GroupedListBoxDemo"
             x:DataType="vm:GroupedListBoxViewModel">

  <ScrollViewer>
    <StackPanel Margin="20" Spacing="30">

      <!-- Scenario 1: Named Groups -->
      <StackPanel Spacing="10">
        <TextBlock FontWeight="Bold" FontSize="16">Scenario 1: Named Groups</TextBlock>
        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextControlPlaceholderForeground}">
          Items are organized into collapsible groups (Meats, Fruits, Vegetables) using GroupBinding and GroupOrderSelector.
        </TextBlock>

        <Border BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                Padding="8"
                CornerRadius="4"
                Background="{DynamicResource LayoutBackgroundLowBrush}">
          <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Selected:" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding SelectedGroupedItem.Name, FallbackValue='(none)'}" />
              <TextBlock Text="-" IsVisible="{Binding SelectedGroupedItem, Converter={x:Static ObjectConverters.IsNotNull}}"/>
              <TextBlock Text="{Binding SelectedGroupedItem.Category}"
                         Foreground="{DynamicResource TextControlPlaceholderForeground}"
                         IsVisible="{Binding SelectedGroupedItem, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Double-clicked:" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding DoubleClickedGroupedItem.Name, FallbackValue='(none)'}" />
              <TextBlock Text="-" IsVisible="{Binding DoubleClickedGroupedItem, Converter={x:Static ObjectConverters.IsNotNull}}"/>
              <TextBlock Text="{Binding DoubleClickedGroupedItem.Category}"
                         Foreground="{DynamicResource TextControlPlaceholderForeground}"
                         IsVisible="{Binding DoubleClickedGroupedItem, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <Grid Height="400" ColumnDefinitions="2*,Auto,*">
          <GroupedListBox Grid.Column="0"
                                   ItemsSource="{Binding GroupedItems}"
                                   SelectedItem="{Binding SelectedGroupedItem}"
                                   GroupBinding="{Binding Category}"
                                   GroupOrderSelector="{Binding CategoryGroupOrderSelector}"
                                   GroupOrderAlphabetical="True"
                                   DoubleTapped="GroupedListBox_OnDoubleTapped">
            <GroupedListBox.ItemTemplate>
              <DataTemplate DataType="vm:FoodItem">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="4">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding Category}"
                             FontSize="11"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource TextControlPlaceholderForeground}"/>
                </StackPanel>
              </DataTemplate>
            </GroupedListBox.ItemTemplate>
          </GroupedListBox>

          <GridSplitter Grid.Column="1" Width="4" Background="{DynamicResource BorderBrush}"/>

          <TextBlock Grid.Column="2"
                     Text="← Drag splitter to resize"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextControlPlaceholderForeground}"/>
        </Grid>
      </StackPanel>

      <!-- Scenario 2: Empty Group First -->
      <StackPanel Spacing="10">
        <TextBlock FontWeight="Bold" FontSize="16">Scenario 2: Groups with Empty Group First</TextBlock>
        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextControlPlaceholderForeground}">
          Items are grouped, with an empty/unnamed group appearing first (using GroupOrderSelector). The unnamed group renders as a bare list (no header).
        </TextBlock>

        <Border BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                Padding="8"
                CornerRadius="4"
                Background="{DynamicResource LayoutBackgroundLowBrush}">
          <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Selected:" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding SelectedEmptyGroupItem.Name, FallbackValue='(none)'}" />
              <TextBlock Text="-" IsVisible="{Binding SelectedEmptyGroupItem, Converter={x:Static ObjectConverters.IsNotNull}}"/>
              <TextBlock Text="{Binding SelectedEmptyGroupItem.Category, FallbackValue='(uncategorized)'}"
                         Foreground="{DynamicResource TextControlPlaceholderForeground}"
                         IsVisible="{Binding SelectedEmptyGroupItem, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Double-clicked:" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding DoubleClickedEmptyGroupItem.Name, FallbackValue='(none)'}" />
              <TextBlock Text="-" IsVisible="{Binding DoubleClickedEmptyGroupItem, Converter={x:Static ObjectConverters.IsNotNull}}"/>
              <TextBlock Text="{Binding DoubleClickedEmptyGroupItem.Category, FallbackValue='(uncategorized)'}"
                         Foreground="{DynamicResource TextControlPlaceholderForeground}"
                         IsVisible="{Binding DoubleClickedEmptyGroupItem, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <Grid Height="400" ColumnDefinitions="2*,Auto,*">
          <GroupedListBox Grid.Column="0"
                                   ItemsSource="{Binding EmptyGroupItems}"
                                   SelectedItem="{Binding SelectedEmptyGroupItem}"
                                   GroupBinding="{Binding Category}"
                                   GroupOrderSelector="{Binding EmptyGroupFirstSelector}"
                                   DoubleTapped="EmptyGroupListBox_OnDoubleTapped">
            <GroupedListBox.ItemTemplate>
              <DataTemplate DataType="vm:FoodItem">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="4">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding Category}"
                             FontSize="11"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource TextControlPlaceholderForeground}"/>
                </StackPanel>
              </DataTemplate>
            </GroupedListBox.ItemTemplate>
          </GroupedListBox>

          <GridSplitter Grid.Column="1" Width="4" Background="{DynamicResource BorderBrush}"/>

          <TextBlock Grid.Column="2"
                     Text="← Drag splitter to resize"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextControlPlaceholderForeground}"/>
        </Grid>
      </StackPanel>

      <!-- Scenario 3: Flat List (No Grouping) -->
      <StackPanel Spacing="10">
        <TextBlock FontWeight="Bold" FontSize="16">Scenario 3: Flat List (No Grouping)</TextBlock>
        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextControlPlaceholderForeground}">
          Items displayed in a flat list without any grouping (no GroupBinding).
        </TextBlock>

        <Border BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                Padding="8"
                CornerRadius="4"
                Background="{DynamicResource LayoutBackgroundLowBrush}">
          <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Selected:" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding SelectedFlatItem.Name, FallbackValue='(none)'}" />
              <TextBlock Text="-" IsVisible="{Binding SelectedFlatItem, Converter={x:Static ObjectConverters.IsNotNull}}"/>
              <TextBlock Text="{Binding SelectedFlatItem.Category}"
                         Foreground="{DynamicResource TextControlPlaceholderForeground}"
                         IsVisible="{Binding SelectedFlatItem, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Double-clicked:" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding DoubleClickedFlatItem.Name, FallbackValue='(none)'}" />
              <TextBlock Text="-" IsVisible="{Binding DoubleClickedFlatItem, Converter={x:Static ObjectConverters.IsNotNull}}"/>
              <TextBlock Text="{Binding DoubleClickedFlatItem.Category}"
                         Foreground="{DynamicResource TextControlPlaceholderForeground}"
                         IsVisible="{Binding DoubleClickedFlatItem, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <Grid Height="400" ColumnDefinitions="2*,Auto,*">
          <GroupedListBox Grid.Column="0"
                                   ItemsSource="{Binding FlatItems}"
                                   SelectedItem="{Binding SelectedFlatItem}"
                                   DoubleTapped="FlatListBox_OnDoubleTapped">
            <GroupedListBox.ItemTemplate>
              <DataTemplate DataType="vm:FoodItem">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="4">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding Category}"
                             FontSize="11"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource TextControlPlaceholderForeground}"/>
                </StackPanel>
              </DataTemplate>
            </GroupedListBox.ItemTemplate>
          </GroupedListBox>

          <GridSplitter Grid.Column="1" Width="4" Background="{DynamicResource BorderBrush}"/>

          <TextBlock Grid.Column="2"
                     Text="← Drag splitter to resize"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextControlPlaceholderForeground}"/>
        </Grid>
      </StackPanel>

      <!-- Scenario 4: Large Dataset -->
      <StackPanel Spacing="10">
        <TextBlock FontWeight="Bold" FontSize="16">Scenario 4: Large Dataset</TextBlock>
        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextControlPlaceholderForeground}">
          500 items across 3 categories (Alpha ×200, Beta ×200, Gamma ×100). Tests behavior with many items per group.
        </TextBlock>

        <Border BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                Padding="8"
                CornerRadius="4"
                Background="{DynamicResource LayoutBackgroundLowBrush}">
          <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Selected:" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding SelectedLargeItem.Name, FallbackValue='(none)'}" />
              <TextBlock Text="-" IsVisible="{Binding SelectedLargeItem, Converter={x:Static ObjectConverters.IsNotNull}}"/>
              <TextBlock Text="{Binding SelectedLargeItem.Category}"
                         Foreground="{DynamicResource TextControlPlaceholderForeground}"
                         IsVisible="{Binding SelectedLargeItem, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Double-clicked:" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding DoubleClickedLargeItem.Name, FallbackValue='(none)'}" />
              <TextBlock Text="-" IsVisible="{Binding DoubleClickedLargeItem, Converter={x:Static ObjectConverters.IsNotNull}}"/>
              <TextBlock Text="{Binding DoubleClickedLargeItem.Category}"
                         Foreground="{DynamicResource TextControlPlaceholderForeground}"
                         IsVisible="{Binding DoubleClickedLargeItem, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <Grid Height="400" ColumnDefinitions="2*,Auto,*">
          <GroupedListBox Grid.Column="0"
                                   ItemsSource="{Binding LargeItems}"
                                   SelectedItem="{Binding SelectedLargeItem}"
                                   GroupBinding="{Binding Category}"
                                   GroupsExpandedByDefault="False"
                                   DoubleTapped="LargeListBox_OnDoubleTapped">
            <GroupedListBox.ItemTemplate>
              <DataTemplate DataType="vm:FoodItem">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="4">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding Category}"
                             FontSize="11"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource TextControlPlaceholderForeground}"/>
                </StackPanel>
              </DataTemplate>
            </GroupedListBox.ItemTemplate>
          </GroupedListBox>

          <GridSplitter Grid.Column="1" Width="4" Background="{DynamicResource BorderBrush}"/>

          <TextBlock Grid.Column="2"
                     Text="← Drag splitter to resize"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextControlPlaceholderForeground}"/>
        </Grid>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>

</UserControl>
