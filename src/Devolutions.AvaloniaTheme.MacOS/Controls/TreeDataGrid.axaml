<!-- TreeDataGrid theme aligned to DataGrid naming/brushes.
     In :flat mode this looks like the macOS DataGrid (no grid lines, alternating rows,
     rounded accent-bar selection).  In :hierarchical mode it looks like the macOS TreeView
     (no grid lines, rounded-row accent selection, sidebar chevrons).
     Global styles in TreeDataGrid.styles.axaml toggle the differences via
     :flat / :hierarchical pseudo-classes set by TreeDataGridPseudoTypeBehavior. -->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="using:Avalonia.Controls.Converters">

  <!-- Theme dictionaries reuse DataGrid brush keys so both controls
       draw from the same palette -->
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Default">
      <!-- Use the SAME keys your DataGrid theme uses -->
      <SolidColorBrush x:Key="DataGridGridLinesBrush" Color="{DynamicResource SystemBaseMediumLowColor}" Opacity="0.4" />
      <SolidColorBrush x:Key="DataGridCellFocusVisualPrimaryBrush" Color="{DynamicResource SystemBaseHighColor}" />
      <SolidColorBrush x:Key="DataGridCellFocusVisualSecondaryBrush" Color="{DynamicResource SystemAltMediumColor}" />
      <SolidColorBrush x:Key="DataGridRowInvalidBrush" Color="{DynamicResource SystemErrorTextColor}" />
      <SolidColorBrush x:Key="DataGridCellInvalidBrush" Color="{DynamicResource SystemErrorTextColor}" />
      <SolidColorBrush x:Key="DataGridDetailsPresenterBackgroundBrush" Color="{DynamicResource SystemChromeMediumLowColor}" />
      <!-- Header hover/pressed using your system colors -->
      <SolidColorBrush x:Key="TreeDataGridHeaderBackgroundPointerOverBrush" Color="{DynamicResource SystemBaseHighColor}" Opacity="0.1" />
      <SolidColorBrush x:Key="TreeDataGridHeaderBackgroundPressedBrush" Color="{DynamicResource SystemBaseMediumLowColor}" />
      <SolidColorBrush x:Key="TreeDataGridHeaderBorderBrushPointerOverBrush" Color="Transparent" />
      <SolidColorBrush x:Key="TreeDataGridHeaderBorderBrushPressedBrush" Color="Transparent" />
      <SolidColorBrush x:Key="TreeDataGridHeaderForegroundPointerOverBrush" Color="{DynamicResource SystemBaseHighColor}" />
      <SolidColorBrush x:Key="TreeDataGridHeaderForegroundPressedBrush" Color="{DynamicResource SystemBaseHighColor}" />
      <!-- Selection background aligned with your DataGrid -->
      <SolidColorBrush x:Key="TreeDataGridSelectedCellBackgroundBrush" Color="{DynamicResource SystemAccentColor}" Opacity="0.4" />
      <StaticResource x:Key="TreeDataGridHeaderForegroundBrush" ResourceKey="ForegroundHighBrush" />
    </ResourceDictionary>
    <ResourceDictionary x:Key="Dark">
      <SolidColorBrush x:Key="DataGridGridLinesBrush" Color="{DynamicResource SystemBaseMediumLowColor}" Opacity="0.4" />
      <SolidColorBrush x:Key="DataGridCellFocusVisualPrimaryBrush" Color="{DynamicResource SystemBaseHighColor}" />
      <SolidColorBrush x:Key="DataGridCellFocusVisualSecondaryBrush" Color="{DynamicResource SystemAltMediumColor}" />
      <SolidColorBrush x:Key="DataGridRowInvalidBrush" Color="{DynamicResource SystemErrorTextColor}" />
      <SolidColorBrush x:Key="DataGridCellInvalidBrush" Color="{DynamicResource SystemErrorTextColor}" />
      <SolidColorBrush x:Key="DataGridDetailsPresenterBackgroundBrush" Color="{DynamicResource SystemChromeMediumLowColor}" />
      <SolidColorBrush x:Key="TreeDataGridHeaderBackgroundPointerOverBrush" Color="{DynamicResource SystemBaseHighColor}" Opacity="0.1" />
      <SolidColorBrush x:Key="TreeDataGridHeaderBackgroundPressedBrush" Color="{DynamicResource SystemBaseMediumLowColor}" />
      <SolidColorBrush x:Key="TreeDataGridHeaderBorderBrushPointerOverBrush" Color="Transparent" />
      <SolidColorBrush x:Key="TreeDataGridHeaderBorderBrushPressedBrush" Color="Transparent" />
      <SolidColorBrush x:Key="TreeDataGridHeaderForegroundPointerOverBrush" Color="{DynamicResource SystemBaseHighColor}" />
      <SolidColorBrush x:Key="TreeDataGridHeaderForegroundPressedBrush" Color="{DynamicResource SystemBaseHighColor}" />
      <SolidColorBrush x:Key="TreeDataGridSelectedCellBackgroundBrush" Color="{DynamicResource SystemAccentColor}" Opacity="0.4" />
      <StaticResource x:Key="TreeDataGridHeaderForegroundBrush" ResourceKey="ForegroundHighBrush" />
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>

  <!-- Reuse DataGrid sizing where it makes sense -->
  <StaticResource x:Key="TreeDataGridRowBackgroundBrush" ResourceKey="SystemControlTransparentBrush" />
  <x:Double x:Key="DataGridSortIconMinWidth">32</x:Double>

  <!-- ================================================================ -->
  <!--  TreeDataGrid root                                               -->
  <!-- ================================================================ -->
  <ControlTheme x:Key="{x:Type TreeDataGrid}" TargetType="TreeDataGrid">
    <!-- Match DataGrid: SystemRegionBrush for background, DataGridGridLinesBrush for border -->
    <Setter Property="Background" Value="{DynamicResource SystemRegionBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DataGridGridLinesBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource ForegroundHighBrush}" />
    <!-- Enable :flat / :hierarchical pseudo-classes automatically -->
    <Setter Property="TreeDataGridPseudoTypeBehavior.Enable" Value="True" />
    <Setter Property="Template">
      <ControlTemplate>
        <Panel>
          <!--
                        Note: This double-border trick is for fixing clipping issue with rounded corners.
                              remove once this issue is fixed:
                              https://github.com/AvaloniaUI/Avalonia/issues/2105
                              - sbergerondrouin 2026/01/29
                    -->
          <Border Name="DataGridBorder"
                  Background="Transparent"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  IsHitTestVisible="False"
                  ZIndex="999" />

          <Border CornerRadius="{TemplateBinding CornerRadius}" ClipToBounds="True" BorderThickness="0" ZIndex="1">
            <Grid RowDefinitions="Auto,*" ColumnDefinitions="*"
                  ZIndex="2"
                  Background="{TemplateBinding Background}">

              <!-- Column headers -->
              <ScrollViewer Name="PART_HeaderScrollViewer"
                            Grid.Row="0"
                            IsVisible="{TemplateBinding ShowColumnHeaders}"
                            HorizontalScrollBarVisibility="Hidden"
                            VerticalScrollBarVisibility="Disabled"
                            BringIntoViewOnFocusChange="{TemplateBinding (ScrollViewer.BringIntoViewOnFocusChange)}">
                <Border Name="ColumnHeadersPresenterBorder"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource DataGridGridLinesBrush}"
                        CornerRadius="{TemplateBinding CornerRadius,
                                            Converter={x:Static DevoConverters.CornerRadiusExtractor},
                                            ConverterParameter={x:Static CornerRadiusSubset.Top}
                                        }">
                  <TreeDataGridColumnHeadersPresenter Name="PART_ColumnHeadersPresenter"
                                                      ElementFactory="{TemplateBinding ElementFactory}"
                                                      Items="{TemplateBinding Columns}"
                                                      ItemContainerTheme="{TemplateBinding ColumnHeaderTheme}" />
                </Border>
              </ScrollViewer>

              <!-- Rows -->
              <ScrollViewer Name="PART_ScrollViewer"
                            Grid.Row="1"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto"
                            BringIntoViewOnFocusChange="{TemplateBinding (ScrollViewer.BringIntoViewOnFocusChange)}">
                <TreeDataGridRowsPresenter Name="PART_RowsPresenter"
                                           Columns="{TemplateBinding Columns}"
                                           ElementFactory="{TemplateBinding ElementFactory}"
                                           Items="{TemplateBinding Rows}" />
              </ScrollViewer>
            </Grid>
          </Border>
        </Panel>
      </ControlTemplate>
    </Setter>
  </ControlTheme>

  <!-- ================================================================ -->
  <!--  Column Header - mirrors DataGridColumnHeader exactly            -->
  <!-- ================================================================ -->
  <ControlTheme x:Key="{x:Type TreeDataGridColumnHeader}" TargetType="TreeDataGridColumnHeader">
    <Setter Property="Foreground" Value="{DynamicResource ForegroundMidBrush}" />
    <Setter Property="Background" Value="{DynamicResource TransparentBrush}" />
    <Setter Property="MinHeight" Value="28" />
    <!-- Match DataGrid: 18,0,0,0 padding -->
    <Setter Property="Padding" Value="18,0,0,0" />
    <Setter Property="BorderBrush" Value="{DynamicResource DataGridGridLinesBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="FontSize" Value="{DynamicResource DataGridColumnHeaderFontSize}" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="HeaderBorder"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="0"
                CornerRadius="{TemplateBinding CornerRadius}">
          <Grid Name="PART_ColumnHeaderRoot" ColumnDefinitions="*,Auto">
            <!-- Main content area with sort icon -->
            <Panel Margin="{TemplateBinding Padding}"
                   HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                   VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" MinWidth="{DynamicResource DataGridSortIconMinWidth}" />
                </Grid.ColumnDefinitions>

                <ContentPresenter Name="PART_ContentPresenter"
                                  Content="{TemplateBinding Header}"
                                  ContentTemplate="{TemplateBinding ContentTemplate}">
                  <ContentPresenter.DataTemplates>
                    <DataTemplate DataType="x:String">
                      <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                  </ContentPresenter.DataTemplates>
                </ContentPresenter>

                <Path Name="SortIcon"
                      IsVisible="False"
                      Grid.Column="1"
                      Width="{DynamicResource DataGridSortChevronSize}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Fill="{DynamicResource SortIconForegroundBrush}"
                      Stretch="Uniform" />
              </Grid>
            </Panel>

            <!-- Right vertical separator (like DataGrid) -->
            <Rectangle Name="VerticalSeparator"
                       Grid.Column="1"
                       Width="1"
                       Height="16"
                       VerticalAlignment="Center"
                       Fill="{TemplateBinding BorderBrush}" />

            <!-- Resizer thumb overlaid on separator -->
            <Thumb Name="PART_Resizer"
                   Grid.Column="1"
                   Background="Transparent"
                   Cursor="SizeWestEast"
                   IsVisible="{TemplateBinding CanUserResize}"
                   Width="5">
              <Thumb.Template>
                <ControlTemplate>
                  <Border Background="{TemplateBinding Background}" VerticalAlignment="Stretch" />
                </ControlTemplate>
              </Thumb.Template>
            </Thumb>
          </Grid>
        </Border>
      </ControlTemplate>
    </Setter>

    <!-- Pointer states -->
    <Style Selector="^:pressed /template/ Grid#PART_ColumnHeaderRoot">
      <Setter Property="Background" Value="{DynamicResource LayoutBackgroundLowBrush}" />
    </Style>

    <!-- Sort adorners (match DataGrid ascending=chevron-up, descending=chevron-down via rotation) -->
    <Style Selector="^[SortDirection=Ascending]">
      <Setter Property="Foreground" Value="{DynamicResource ForegroundHighBrush}" />
      <Setter Property="FontWeight" Value="Medium" />
      <Style Selector="^ /template/ Path#SortIcon">
        <Setter Property="IsVisible" Value="True" />
        <Setter Property="Data" Value="{StaticResource ChevronPath}" />
      </Style>
    </Style>
    <Style Selector="^[SortDirection=Descending]">
      <Setter Property="Foreground" Value="{DynamicResource ForegroundHighBrush}" />
      <Setter Property="FontWeight" Value="Medium" />
      <Style Selector="^ /template/ Path#SortIcon">
        <Setter Property="IsVisible" Value="True" />
        <Setter Property="Data" Value="{StaticResource ChevronPath}" />
        <Setter Property="RenderTransform">
          <TransformGroup>
            <RotateTransform Angle="180" />
          </TransformGroup>
        </Setter>
      </Style>
    </Style>
  </ControlTheme>

  <!-- ================================================================ -->
  <!--  Row                                                             -->
  <!--  Like DataGrid: ItemBorder (sibling of cells) holds the         -->
  <!--  selection/alternation background with its own margin +          -->
  <!--  CornerRadius, while cells remain edge-to-edge so they align    -->
  <!--  with the column headers.                                       -->
  <!-- ================================================================ -->
  <ControlTheme x:Key="{x:Type TreeDataGridRow}" TargetType="TreeDataGridRow">
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="{Binding $parent[TreeDataGrid].Background}" />
    <Setter Property="MinHeight" Value="22" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border x:Name="RowBorder"
                Background="Transparent"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}">
          <Grid>
            <!-- Selection / alternation background (positioned behind cells).
                             Margin and CornerRadius are set by global styles per mode. -->
            <Border Name="ItemBorder"
                    Background="{TemplateBinding Background}"
                    Margin="{DynamicResource DataGridRowMargin}"
                    CornerRadius="{DynamicResource ControlCornerRadius}" />
            <!-- Invalid overlay like DataGrid -->
            <Rectangle Name="InvalidVisualElement"
                       Opacity="0"
                       Fill="{DynamicResource DataGridRowInvalidBrush}" />
            <!-- Cells stay edge-to-edge (matching header alignment) -->
            <TreeDataGridCellsPresenter Name="PART_CellsPresenter"
                                        ElementFactory="{TemplateBinding ElementFactory}"
                                        Items="{TemplateBinding Columns}"
                                        Rows="{TemplateBinding Rows}"
                                        Margin="{DynamicResource DataGridRowPadding}" />
          </Grid>
        </Border>
      </ControlTemplate>
    </Setter>

    <!-- Selected: accent background on inner ItemBorder (like DataGrid) -->
    <Style Selector="^:selected /template/ Border#ItemBorder">
      <Setter Property="Background" Value="{WindowActiveResourceToggler DataGridItemBackgroundSelected, SelectionInInactiveWindow}" />
    </Style>

    <Style Selector="^:invalid /template/ Rectangle#InvalidVisualElement">
      <Setter Property="Opacity" Value="0.4" />
    </Style>
  </ControlTheme>

  <!-- ================================================================ -->
  <!--  Cells                                                           -->
  <!-- ================================================================ -->
  <ControlTheme x:Key="{x:Type TreeDataGridTextCell}" TargetType="TreeDataGridTextCell">
    <Setter Property="Padding" Value="12,0,12,0" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground"
            Value="{DynamicResourceToggler
                    {AndBinding
              {WindowIsActiveBinding},
              {OrBinding
                          {SelfBinding IsSelected},
                {Binding IsSelected, RelativeSource={RelativeSource FindAncestor, AncestorType=TreeDataGridRow}}
              }
                    },
                    DataGridForegroundSelectedBrush,
                    ForegroundHighBrush
                }" />
    <Setter Property="FontSize" Value="{DynamicResource ControlFontSize}" />
    <Setter Property="MinHeight" Value="23" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border x:Name="CellBorder"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <Grid>
            <!-- Focus ring for cell-selection mode -->
            <Border Name="FocusVisual"
                    IsHitTestVisible="False"
                    IsVisible="False"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Margin="3 2"
                    BorderBrush="Transparent"
                    BorderThickness="1"
                    CornerRadius="5" />
            <Border Padding="{TemplateBinding Padding}">
              <TextBlock Text="{TemplateBinding Value}"
                         Foreground="{TemplateBinding Foreground}"
                         TextTrimming="{TemplateBinding TextTrimming}"
                         TextWrapping="{TemplateBinding TextWrapping}"
                         TextAlignment="{TemplateBinding TextAlignment}"
                         VerticalAlignment="Center" />
            </Border>
          </Grid>
        </Border>
      </ControlTemplate>
    </Setter>

    <!-- Cell selected: accent background (for cell-selection mode) -->
    <Style Selector="^:selected /template/ Border#FocusVisual">
      <Setter Property="Background" Value="{WindowActiveResourceToggler DataGridItemBackgroundSelected, SelectionInInactiveWindow}" />
      <Setter Property="BorderBrush" Value="{WindowActiveResourceToggler DataGridItemBackgroundSelected, SelectionInInactiveWindow}" />
      <Setter Property="IsVisible" Value="True" />
    </Style>
    <Style Selector="^:selected:focus /template/ Border#FocusVisual">
      <Setter Property="BorderBrush" Value="{DynamicResource DataGridCellBorderSelectedBrush}" />
    </Style>
  </ControlTheme>

  <ControlTheme x:Key="{x:Type TreeDataGridTemplateCell}" TargetType="TreeDataGridTemplateCell">
    <Setter Property="Padding" Value="12,0,12,0" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground"
        Value="{DynamicResourceToggler
            {AndBinding
              {WindowIsActiveBinding},
              {OrBinding
                          {SelfBinding IsSelected},
                {Binding IsSelected, RelativeSource={RelativeSource FindAncestor, AncestorType=TreeDataGridRow}}
              }
            },
            DataGridForegroundSelectedBrush,
            ForegroundHighBrush
          }" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border x:Name="CellBorder"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <Panel>
            <Border Name="FocusVisual"
                    IsHitTestVisible="False"
                    IsVisible="False"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Margin="3 2"
                    BorderBrush="{DynamicResource DataGridCellBorderSelectedBrush}"
                    BorderThickness="1"
                    CornerRadius="5" />
            <ContentPresenter Name="PART_ContentPresenter"
                              Margin="-9 0 0 0"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              Content="{TemplateBinding Content}"
                              TextElement.Foreground="{TemplateBinding Foreground}"
                              Padding="{TemplateBinding Padding}" />
          </Panel>
        </Border>
      </ControlTemplate>
    </Setter>

    <Style Selector="^:selected /template/ Border#CellBorder">
      <Setter Property="Background" Value="{WindowActiveResourceToggler DataGridItemBackgroundSelected, SelectionInInactiveWindow}" />
    </Style>
    <Style Selector="^:selected /template/ Border#FocusVisual">
      <Setter Property="IsVisible" Value="True" />
    </Style>
  </ControlTheme>

  <ControlTheme x:Key="{x:Type TreeDataGridCheckBoxCell}" TargetType="TreeDataGridCheckBoxCell">
    <Setter Property="Padding" Value="12,0,12,0" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border x:Name="CellBorder"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <Grid>
            <Border Name="FocusVisual"
                    IsHitTestVisible="False"
                    IsVisible="False"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Margin="3 2"
                    BorderBrush="{DynamicResource DataGridCellBorderSelectedBrush}"
                    BorderThickness="1"
                    CornerRadius="5" />
            <Border Padding="{TemplateBinding Padding}">
              <CheckBox IsChecked="{TemplateBinding Value, Mode=TwoWay}"
                        IsEnabled="{Binding !IsReadOnly, RelativeSource={RelativeSource TemplatedParent}}"
                        IsThreeState="{TemplateBinding IsThreeState}" />
            </Border>
          </Grid>
        </Border>
      </ControlTemplate>
    </Setter>

    <Style Selector="^:selected /template/ Border#CellBorder">
      <Setter Property="Background" Value="{WindowActiveResourceToggler DataGridItemBackgroundSelected, SelectionInInactiveWindow}" />
    </Style>
    <Style Selector="^:selected /template/ Border#FocusVisual">
      <Setter Property="IsVisible" Value="True" />
    </Style>
  </ControlTheme>

  <!-- ================================================================ -->
  <!--  Expander chevron - macOS sidebar style (rotated chevron)        -->
  <!-- ================================================================ -->
  <ControlTheme x:Key="TreeDataGridExpandCollapseChevron" TargetType="ToggleButton">
    <Setter Property="Margin" Value="0" />
    <Setter Property="Width" Value="{StaticResource TreeViewItemChevronSize}" />
    <Setter Property="Height" Value="{StaticResource TreeViewItemChevronSize}" />
    <Setter Property="Foreground" Value="{DynamicResource ForegroundMidBrush}" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="Transparent"
                Width="{TemplateBinding Width}"
                Height="{TemplateBinding Height}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <Path x:Name="ChevronPath"
                Data="{StaticResource ChevronPath}"
                Fill="{TemplateBinding Foreground}"
                Stretch="Uniform"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Path.RenderTransform>
              <TransformGroup>
                <RotateTransform Angle="90" />
              </TransformGroup>
            </Path.RenderTransform>
          </Path>
        </Border>
      </ControlTemplate>
    </Setter>

    <Style Selector="^:checked /template/ Path#ChevronPath">
      <Setter Property="RenderTransform">
        <RotateTransform Angle="180" />
      </Setter>
    </Style>
  </ControlTheme>

  <ControlTheme x:Key="{x:Type TreeDataGridExpanderCell}" TargetType="TreeDataGridExpanderCell">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground"
            Value="{DynamicResourceToggler
                    {AndBinding
                        {WindowIsActiveBinding},
                        {OrBinding
                          {SelfBinding IsSelected},
                            {Binding IsSelected, RelativeSource={RelativeSource FindAncestor, AncestorType=TreeDataGridRow}}
                        }
                    },
                    DataGridForegroundSelectedBrush,
                    ForegroundMidBrush
                }" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border x:Name="CellBorder"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}"
                Padding="{TemplateBinding Indent, Converter={x:Static conv:IndentConverter.Instance}}">
          <DockPanel>
            <Border DockPanel.Dock="Left"
                    Margin="{StaticResource TreeViewItemChevronMargin}"
                    Width="{StaticResource TreeViewItemChevronSize}">
              <ToggleButton Theme="{StaticResource TreeDataGridExpandCollapseChevron}"
                            Focusable="False"
                            Foreground="{TemplateBinding Foreground}"
                            IsChecked="{TemplateBinding IsExpanded, Mode=TwoWay}"
                            IsVisible="{TemplateBinding ShowExpander}" />
            </Border>
            <Decorator Name="PART_Content"
                       TextElement.Foreground="{TemplateBinding Foreground}" />
          </DockPanel>
        </Border>
      </ControlTemplate>
    </Setter>

    <!-- Cell selected in cell-selection mode -->
    <Style Selector="^:selected /template/ Border#CellBorder">
      <Setter Property="Background" Value="{WindowActiveResourceToggler DataGridItemBackgroundSelected, SelectionInInactiveWindow}" />
    </Style>
  </ControlTheme>

</ResourceDictionary>