<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- WinUI NavigationViewItem-style ListBoxItem.
       Apply via Theme="{StaticResource WinUiNavItemTheme}" on ListBoxItem controls.
       Provides a neutral-fill hover/selected state with a vertical accent pill on the left edge,
       matching WinUI's NavigationViewItem selection indicator rather than Fluent's full accent fill. -->
  <ControlTheme x:Key="WinUiNavItemTheme" TargetType="ListBoxItem"
                BasedOn="{StaticResource {x:Type ListBoxItem}}">
    <Setter Property="Template">
      <ControlTemplate>
        <Panel>
          <ContentPresenter Name="ContentHost"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Content="{TemplateBinding Content}"
                            Padding="{TemplateBinding Padding}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"/>
          <Border Name="SelectionPill"
                  Width="3" Height="16" CornerRadius="1.5"
                  Background="{DynamicResource AccentFillColorDefaultBrush}"
                  HorizontalAlignment="Left" VerticalAlignment="Center"
                  Opacity="0">
            <Border.Transitions>
              <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.1"/>
              </Transitions>
            </Border.Transitions>
          </Border>
        </Panel>
      </ControlTemplate>
    </Setter>
    <Style Selector="^:pointerover /template/ ContentPresenter#ContentHost">
      <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
    </Style>
    <Style Selector="^:pressed /template/ ContentPresenter#ContentHost">
      <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
    </Style>
    <Style Selector="^:selected /template/ ContentPresenter#ContentHost">
      <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
    </Style>
    <Style Selector="^:selected:pointerover /template/ ContentPresenter#ContentHost">
      <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
    </Style>
    <Style Selector="^:selected /template/ Border#SelectionPill">
      <Setter Property="Opacity" Value="1"/>
    </Style>
  </ControlTheme>

  <!-- WinUI Segmented-control-style ListBoxItem.
       Apply via Theme="{StaticResource WinUiSegmentItemTheme}" on ListBoxItem controls.
       Shows a neutral-fill on hover/select and an accent underline on the selected segment,
       matching WinUI's Segmented control rather than Fluent's full accent fill. -->
  <ControlTheme x:Key="WinUiSegmentItemTheme" TargetType="ListBoxItem"
                BasedOn="{StaticResource {x:Type ListBoxItem}}">
    <Setter Property="Template">
      <ControlTemplate>
        <Panel>
          <ContentPresenter Name="ContentHost"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Content="{TemplateBinding Content}"
                            Padding="{TemplateBinding Padding}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"/>
          <Border Name="SelectionPill"
                  Height="2" CornerRadius="1"
                  Background="{DynamicResource AccentFillColorDefaultBrush}"
                  HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                  Margin="5,0,5,2"
                  Opacity="0">
            <Border.Transitions>
              <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.1"/>
              </Transitions>
            </Border.Transitions>
          </Border>
        </Panel>
      </ControlTemplate>
    </Setter>
    <Style Selector="^:pointerover /template/ ContentPresenter#ContentHost">
      <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
    </Style>
    <Style Selector="^:selected /template/ ContentPresenter#ContentHost">
      <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
    </Style>
    <Style Selector="^:selected:pointerover /template/ ContentPresenter#ContentHost">
      <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
    </Style>
    <Style Selector="^:selected /template/ Border#SelectionPill">
      <Setter Property="Opacity" Value="1"/>
    </Style>
  </ControlTheme>

</ResourceDictionary>
