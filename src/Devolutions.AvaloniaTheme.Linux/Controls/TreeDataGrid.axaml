<!-- TreeDataGrid theme aligned to DataGrid naming/brushes -->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="using:Avalonia.Controls.Converters">
  <!-- NOTE:
     Some resources from DataGrid.axaml are used here too.
  -->

  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Default">
      <SolidColorBrush x:Key="TreeDataGridBackgroundBrush" Color="#FFF" />
      <SolidColorBrush x:Key="TreeDataGridForegroundBrush" Color="#101010" />

      <SolidColorBrush x:Key="TreeDataGridSelectedCellBackgroundBrush" Color="{DynamicResource SystemAccentColor}" Opacity="0.4" />

      <SolidColorBrush x:Key="TreeDataGridHeaderForegroundBrush" Color="#b1b1b1" />
      <SolidColorBrush x:Key="TreeDataGridHeaderForegroundPointerOverBrush">#777777</SolidColorBrush>
      <SolidColorBrush x:Key="TreeDataGridHeaderForegroundPressedBrush">#3d3d3d</SolidColorBrush>
      <SolidColorBrush x:Key="TreeDataGridHeaderBorderBrushPointerOverBrush">#dadada</SolidColorBrush>
      <SolidColorBrush x:Key="TreeDataGridHeaderBorderBrushPressedBrush">#dadada</SolidColorBrush>
      <BoxShadows x:Key="TreeDataGridHeaderBoxShadow">0 0 4 0 #40000000</BoxShadows>
    </ResourceDictionary>
    <ResourceDictionary x:Key="Dark">
      <SolidColorBrush x:Key="TreeDataGridBackgroundBrush" Color="#1E1E1E" />
      <SolidColorBrush x:Key="TreeDataGridForegroundBrush" Color="#e0e0e0" />

      <SolidColorBrush x:Key="TreeDataGridSelectedCellBackgroundBrush" Color="{DynamicResource SystemAccentColor}" Opacity="0.4" />

      <SolidColorBrush x:Key="TreeDataGridHeaderForegroundBrush" Color="#757575" />
      <SolidColorBrush x:Key="TreeDataGridHeaderForegroundPointerOverBrush">#b6b6b6</SolidColorBrush>
      <SolidColorBrush x:Key="TreeDataGridHeaderForegroundPressedBrush">#f7f7f7</SolidColorBrush>
      <SolidColorBrush x:Key="TreeDataGridHeaderBorderBrushPointerOverBrush">#404040</SolidColorBrush>
      <SolidColorBrush x:Key="TreeDataGridHeaderBorderBrushPressedBrush">#404040</SolidColorBrush>
      <BoxShadows x:Key="TreeDataGridHeaderBoxShadow">0 0 4 0 #CC000000</BoxShadows>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>

  <!-- Sort/chevron geometry -->
  <StreamGeometry x:Key="DevoDataGridItemCollapsedChevronPathData">M 1,0 10,10 l -9,10 -1,-1 L 8,10 -0,1 Z</StreamGeometry>
  <StreamGeometry x:Key="DevoDataGridItemExpandedChevronPathData">M0,1 L10,10 20,1 19,0 10,8 1,0 Z</StreamGeometry>
  <StreamGeometry x:Key="DevoDataGridSortIconPath">M1881.76,1161.76l-876.76,-876.76L126.68,1163.32C82.97,1163.32,0,1005,0,1005l1005,-1005L2010,1005,1881.76,1161.76Z</StreamGeometry>

  <!-- TreeDataGrid root: align with DataGrid container visuals -->
  <ControlTheme x:Key="{x:Type TreeDataGrid}" TargetType="TreeDataGrid">
    <Setter Property="Background" Value="{DynamicResource TreeDataGridBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TreeDataGridForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Template">
      <ControlTemplate>
        <Panel>
          <!--
              Note: This double-border trick is for fixing clipping issue with rounded corners.
                    remove once this issue is fixed: 
                    https://github.com/AvaloniaUI/Avalonia/issues/2105
                    - sbergerondrouin 2026/01/29 
          -->
          <Border Name="DataGridBorder"
                  Background="Transparent"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  IsHitTestVisible="False"
                  ZIndex="999" />

          <Border CornerRadius="{TemplateBinding CornerRadius}" ClipToBounds="True" BorderThickness="0" ZIndex="1">
            <Grid RowDefinitions="Auto,*" ColumnDefinitions="*"
                  ZIndex="2"
                  Background="{TemplateBinding Background}">

              <!-- Column headers: add bottom grid line, reuse DataGridGridLinesBrush -->
              <!-- Shadow overlay: sits in same Grid row as the header ScrollViewer,
                                   rendered outside the ScrollViewer so it isn't clipped by ScrollContentPresenter -->
              <Border Name="HeaderShadow"
                      Grid.Row="0"
                      ZIndex="1"
                      IsHitTestVisible="False"
                      BoxShadow="{DynamicResource TreeDataGridHeaderBoxShadow}"
                      IsVisible="{TemplateBinding ShowColumnHeaders}" />
              <ScrollViewer Name="PART_HeaderScrollViewer"
                            Grid.Row="0"
                            IsVisible="{TemplateBinding ShowColumnHeaders}"
                            HorizontalScrollBarVisibility="Hidden"
                            VerticalScrollBarVisibility="Disabled"
                            BringIntoViewOnFocusChange="{TemplateBinding (ScrollViewer.BringIntoViewOnFocusChange)}">
                <Border Name="ColumnHeadersPresenterBorder"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource DataGridGridLinesBrush}"
                        Background="{DynamicResource TableHeaderBackground}"
                        CornerRadius="{TemplateBinding CornerRadius,
                                            Converter={x:Static DevoConverters.CornerRadiusExtractor},
                                            ConverterParameter={x:Static CornerRadiusSubset.Top}
                                        }">
                  <TreeDataGridColumnHeadersPresenter Name="PART_ColumnHeadersPresenter"
                                                      ElementFactory="{TemplateBinding ElementFactory}"
                                                      Items="{TemplateBinding Columns}"
                                                      ItemContainerTheme="{TemplateBinding ColumnHeaderTheme}" />
                </Border>
              </ScrollViewer>

              <!-- Rows -->
              <ScrollViewer Name="PART_ScrollViewer"
                            Grid.Row="1"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto"
                            BringIntoViewOnFocusChange="{TemplateBinding (ScrollViewer.BringIntoViewOnFocusChange)}">
                <TreeDataGridRowsPresenter Name="PART_RowsPresenter"
                                           Columns="{TemplateBinding Columns}"
                                           ElementFactory="{TemplateBinding ElementFactory}"
                                           Items="{TemplateBinding Rows}" />
              </ScrollViewer>
            </Grid>
          </Border>
        </Panel>
      </ControlTemplate>
    </Setter>
  </ControlTheme>

  <!-- Column Header: mirror DataGridColumnHeader feel -->
  <ControlTheme x:Key="{x:Type TreeDataGridColumnHeader}" TargetType="TreeDataGridColumnHeader">
    <Setter Property="Foreground" Value="{DynamicResource TreeDataGridHeaderForegroundBrush}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="MinHeight" Value="26" />
    <Setter Property="Padding" Value="5 0 0 0" />
    <Setter Property="BorderBrush" Value="{DynamicResource DataGridGridLinesBrush}" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="FontWeight" Value="DemiBold" />
    <Setter Property="FontStretch" Value="SemiExpanded" />

    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="HeaderBorder"
                Background="{TemplateBinding Background}"
                BorderBrush="Transparent"
                BorderThickness="0"
                CornerRadius="{TemplateBinding CornerRadius}">
          <DockPanel VerticalAlignment="Stretch">
            <!-- Right separator + resizer -->
            <Panel DockPanel.Dock="Right" TabIndex="2">
              <Rectangle Fill="{TemplateBinding BorderBrush}"
                         HorizontalAlignment="Right"
                         Width="{TemplateBinding BorderThickness, 
                                           Converter={x:Static DevoConverters.ThicknessNumericExtractor}, 
                                           ConverterParameter={x:Static ThicknessSide.Right}}" />
              <Thumb Name="PART_Resizer"
                     DockPanel.Dock="Right"
                     Background="Transparent"
                     Cursor="SizeWestEast"
                     IsVisible="{TemplateBinding CanUserResize}"
                     Width="5">
                <Thumb.Template>
                  <ControlTemplate>
                    <Border Background="{TemplateBinding Background}" VerticalAlignment="Stretch" />
                  </ControlTemplate>
                </Thumb.Template>
              </Thumb>
            </Panel>

            <!-- Sort icon (reusing DataGrid foreground) -->
            <Path Name="SortIcon"
                  DockPanel.Dock="Right"
                  Fill="{TemplateBinding Foreground}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Stretch="Uniform"
                  Height="7"
                  TabIndex="1"
                  IsVisible="False"
                  Data="{StaticResource DevoDataGridSortIconPath}" />

            <!-- Header content -->
            <ContentPresenter Name="PART_ContentPresenter"
                              Content="{TemplateBinding Header}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              Padding="{TemplateBinding Padding}"
                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                              TabIndex="0">
              <ContentPresenter.DataTemplates>
                <DataTemplate DataType="x:String">
                  <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" />
                </DataTemplate>
              </ContentPresenter.DataTemplates>
            </ContentPresenter>
          </DockPanel>
        </Border>
      </ControlTemplate>
    </Setter>

    <!-- Pointer states, matching your TreeDataGrid defaults -->
    <Style Selector="^:pointerover /template/ Border#HeaderBorder">
      <Setter Property="BorderBrush" Value="{DynamicResource TreeDataGridHeaderBorderBrushPointerOverBrush}" />
      <Setter Property="TextBlock.Foreground" Value="{DynamicResource TreeDataGridHeaderForegroundPointerOverBrush}" />
      <Setter Property="Path.Fill" Value="{DynamicResource TreeDataGridHeaderForegroundPointerOverBrush}" />
    </Style>
    <Style Selector="^:pressed /template/ Border#HeaderBorder">
      <Setter Property="BorderBrush" Value="{DynamicResource TreeDataGridHeaderBorderBrushPressedBrush}" />
      <Setter Property="TextBlock.Foreground" Value="{DynamicResource TreeDataGridHeaderForegroundPressedBrush}" />
      <Setter Property="Path.Fill" Value="{DynamicResource TreeDataGridHeaderForegroundPressedBrush}" />
    </Style>

    <!-- Sort Adorners -->
    <Style Selector="^[SortDirection=Ascending] /template/ Path#SortIcon">
      <Setter Property="IsVisible" Value="True" />
      <Setter Property="RenderTransform" Value="scaleY(-1)" />
    </Style>
    <Style Selector="^[SortDirection=Descending] /template/ Path#SortIcon">
      <Setter Property="IsVisible" Value="True" />
    </Style>
  </ControlTheme>

  <!-- Row: selection + invalid states mirror DataGrid -->
  <ControlTheme x:Key="{x:Type TreeDataGridRow}" TargetType="TreeDataGridRow">
    <Setter Property="BorderBrush" Value="{DynamicResource TableBorder}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="{Binding $parent[TreeDataGrid].Background}" />
    <Setter Property="MinHeight" Value="21" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border x:Name="RowBorder"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <Grid>
            <!-- Alternation/normal background (same key as DataGrid) -->
            <Rectangle Name="BackgroundRectangle"
                       Fill="{DynamicResource DataGridRowBackgroundBrush}" />
            <!-- Invalid overlay like DataGrid -->
            <Rectangle Name="InvalidVisualElement"
                       Opacity="0"
                       Fill="{DynamicResource DataGridRowInvalidBrush}" />
            <TreeDataGridCellsPresenter Name="PART_CellsPresenter"
                                        ElementFactory="{TemplateBinding ElementFactory}"
                                        Items="{TemplateBinding Columns}"
                                        Rows="{TemplateBinding Rows}" />
          </Grid>
        </Border>
      </ControlTemplate>
    </Setter>
    
    <Style Selector="^:selected /template/ TreeDataGridCellsPresenter#PART_CellsPresenter">
      <Setter Property="Background" Value="{DynamicResource TreeDataGridSelectedCellBackgroundBrush}" />
    </Style>

    <Style Selector="^:invalid /template/ Rectangle#InvalidVisualElement">
      <Setter Property="Opacity" Value="0.4" />
    </Style>
    <Style Selector="^:invalid /template/ Rectangle#BackgroundRectangle">
      <Setter Property="Opacity" Value="0" />
    </Style>
  </ControlTheme>

  <!-- Cells -->
  <ControlTheme x:Key="{x:Type TreeDataGridTextCell}" TargetType="TreeDataGridTextCell">
    <Setter Property="Padding" Value="5 0 0 0" />
    <Setter Property="BorderBrush" Value="{DynamicResource DataGridGridLinesBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    
    <Setter Property="Template">
      <ControlTemplate>
        <Border x:Name="CellBorder"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}"
                Padding="{TemplateBinding Padding}">
          <TextBlock Text="{TemplateBinding Value}"
                     TextTrimming="{TemplateBinding TextTrimming}"
                     TextWrapping="{TemplateBinding TextWrapping}"
                     TextAlignment="{TemplateBinding TextAlignment}"
                     VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>

    <Style Selector="^:selected /template/ Border#CellBorder">
      <Setter Property="Background" Value="{DynamicResource TreeDataGridSelectedCellBackgroundBrush}" />
    </Style>
  </ControlTheme>

  <ControlTheme x:Key="{x:Type TreeDataGridTemplateCell}" TargetType="TreeDataGridTemplateCell">
    <Setter Property="Padding" Value="5 0 0 0" />
    <Setter Property="BorderBrush" Value="{DynamicResource DataGridGridLinesBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    
    <Setter Property="Template">
      <ControlTemplate>
        <ContentPresenter Name="PART_ContentPresenter"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          ContentTemplate="{TemplateBinding ContentTemplate}"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          Content="{TemplateBinding Content}"
                          Padding="{TemplateBinding Padding}" />
      </ControlTemplate>
    </Setter>

    <Style Selector="^:selected /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource TreeDataGridSelectedCellBackgroundBrush}" />
    </Style>
  </ControlTheme>

  <ControlTheme x:Key="{x:Type TreeDataGridCheckBoxCell}" TargetType="TreeDataGridCheckBoxCell">
    <Setter Property="Padding" Value="5 0 0 0" />
    <Setter Property="BorderBrush" Value="{DynamicResource DataGridGridLinesBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    
    <Setter Property="Template">
      <ControlTemplate>
        <Border x:Name="CellBorder"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}"
                Padding="{TemplateBinding Padding}">
          <CheckBox IsChecked="{TemplateBinding Value, Mode=TwoWay}"
                    IsEnabled="{Binding !IsReadOnly, RelativeSource={RelativeSource TemplatedParent}}"
                    IsThreeState="{TemplateBinding IsThreeState}" />
        </Border>
      </ControlTemplate>
    </Setter>

    <Style Selector="^:selected /template/ Border#CellBorder">
      <Setter Property="Background" Value="{DynamicResource TreeDataGridSelectedCellBackgroundBrush}" />
    </Style>
  </ControlTheme>

  <!-- Expander: chevron + indent same as original, padding aligns with DataGrid feel -->
  <ControlTheme x:Key="TreeDataGridExpandCollapseChevron" TargetType="ToggleButton">
    <Setter Property="Margin" Value="0" />
    <Setter Property="Width" Value="11" />
    <Setter Property="Height" Value="11" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="Transparent"
                Width="{TemplateBinding Width}"
                Height="{TemplateBinding Height}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <Path x:Name="ChevronPath"
                Data="{StaticResource DevoDataGridItemCollapsedChevronPathData}"
                Fill="{TemplateBinding Foreground}"
                Stretch="Uniform"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>
    <Style Selector="^:checked /template/ Path#ChevronPath">
      <Setter Property="Data" Value="{StaticResource DevoDataGridItemExpandedChevronPathData}" />
    </Style>
  </ControlTheme>

  <ControlTheme x:Key="{x:Type TreeDataGridExpanderCell}" TargetType="TreeDataGridExpanderCell">
    <Setter Property="Background" Value="Transparent" />
    
    <Setter Property="Template">
      <ControlTemplate>
        <Border x:Name="CellBorder"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}"
                Padding="{TemplateBinding Indent, Converter={x:Static conv:IndentConverter.Instance}}">
          <DockPanel>
            <Border DockPanel.Dock="Left" Margin="4 0 0 0" Width="12" Height="12">
              <ToggleButton Theme="{StaticResource TreeDataGridExpandCollapseChevron}"
                            Focusable="False"
                            IsChecked="{TemplateBinding IsExpanded, Mode=TwoWay}"
                            IsVisible="{TemplateBinding ShowExpander}" />
            </Border>
            <Decorator Name="PART_Content" />
          </DockPanel>
        </Border>
      </ControlTemplate>
    </Setter>

    <Style Selector="^:selected /template/ Border#CellBorder">
      <Setter Property="Background" Value="{DynamicResource TreeDataGridSelectedCellBackgroundBrush}" />
    </Style>
  </ControlTheme>

</ResourceDictionary>