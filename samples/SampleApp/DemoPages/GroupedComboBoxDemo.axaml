<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SampleApp.ViewModels"
             xmlns:system="clr-namespace:System;assembly=System.Runtime"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="650"
             x:Class="SampleApp.DemoPages.GroupedComboBoxDemo"
             x:DataType="vm:GroupedComboBoxViewModel">

  <ScrollViewer>
    <StackPanel Margin="20" Spacing="30" MaxWidth="1080" HorizontalAlignment="Left">
      <StackPanel Spacing="6">
        <TextBlock FontWeight="Bold" FontSize="18">GroupedComboBox</TextBlock>
        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextControlPlaceholderForeground}">
          Uses the existing ComboBox template for the control chrome and only changes popup items to show group headers.
        </TextBlock>
      </StackPanel>

      <Grid ColumnDefinitions="Auto,200" ColumnSpacing="20">
      <Border Grid.Column="0" Margin="0" Padding="20" HorizontalAlignment="Left" Background="{DynamicResource LayoutBackgroundLowBrush}">
        <Grid ColumnDefinitions="Auto 220 260" RowDefinitions="Auto Auto Auto Auto Auto Auto Auto" RowSpacing="18" ColumnSpacing="16">
          <TextBlock Grid.Column="0" Grid.Row="0" VerticalAlignment="Top" Margin="0 5 0 0">
            <Bold>Named groups:</Bold>
          </TextBlock>
          <StackPanel Grid.Column="1" Grid.Row="0" Spacing="8">
            <GroupedComboBox ItemsSource="{Binding GroupedItems}"
                             SelectedItem="{Binding SelectedGroupedItem}"
                             PlaceholderText="Choose food"
                             HeaderMargin="{Binding HeaderMargin}"
                             GroupBinding="{Binding Category}"
                             GroupOrderSelector="{Binding CategoryGroupOrderSelector}"
                             GroupOrderAlphabetical="True">
              <GroupedComboBox.ItemTemplate>
                <DataTemplate DataType="vm:FoodItem">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Category}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextControlPlaceholderForeground}" />
                  </StackPanel>
                </DataTemplate>
              </GroupedComboBox.ItemTemplate>
            </GroupedComboBox>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Selected:" FontWeight="SemiBold" />
              <TextBlock Text="{Binding SelectedGroupedItem.Name, FallbackValue='(none)'}" />
            </StackPanel>
          </StackPanel>
          <TextBlock Grid.Column="2" Grid.Row="0" TextWrapping="Wrap" Foreground="{DynamicResource TextControlPlaceholderForeground}">
            Ordered as Meats, Fruits, Vegetables. Edit HeaderMargin while popup is open to verify inherited dynamic updates.
          </TextBlock>

          <TextBlock Grid.Column="0" Grid.Row="1" VerticalAlignment="Top" Margin="0 5 0 0">
            <Bold>Empty group:</Bold>
            <LineBreak />
            <TextBlock Classes="code">EmptyGroupName</TextBlock>
            <LineBreak />
            <Bold>unset</Bold>
          </TextBlock>
          <StackPanel Grid.Column="1" Grid.Row="1" Spacing="8">
            <GroupedComboBox ItemsSource="{Binding EmptyGroupItems}"
                             SelectedItem="{Binding SelectedEmptyGroupItem}"
                             PlaceholderText="Choose item"
                             GroupBinding="{Binding Category}"
                             GroupOrderSelector="{Binding EmptyGroupFirstSelector}"
                             MaxDropDownHeight="220">
              <GroupedComboBox.ItemTemplate>
                <DataTemplate DataType="vm:FoodItem">
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </GroupedComboBox.ItemTemplate>
            </GroupedComboBox>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Selected:" FontWeight="SemiBold" />
              <TextBlock Text="{Binding SelectedEmptyGroupItem.Name, FallbackValue='(none)'}" />
            </StackPanel>
          </StackPanel>
          <TextBlock Grid.Column="2" Grid.Row="1" TextWrapping="Wrap" Foreground="{DynamicResource TextControlPlaceholderForeground}">
            Empty category has no displayed header and occupies no empty header space. Items start at the top of the popup.
          </TextBlock>

          <TextBlock Grid.Column="0" Grid.Row="2" VerticalAlignment="Top" Margin="0 5 0 0">
            <Bold>Empty group:</Bold>
            <LineBreak />
            <TextBlock Classes="code">EmptyGroupName</TextBlock>
            <LineBreak />
            <Bold>set</Bold>
          </TextBlock>
          <StackPanel Grid.Column="1" Grid.Row="2" Spacing="8">
            <GroupedComboBox ItemsSource="{Binding EmptyGroupItems}"
                             SelectedItem="{Binding SelectedEmptyGroupItemWithName}"
                             PlaceholderText="Choose item"
                             HeaderForeground="#266fd2"
                             GroupBinding="{Binding Category}"
                             GroupOrderSelector="{Binding EmptyGroupFirstSelector}"
                             EmptyGroupName="NO GROUP"
                             MaxDropDownHeight="220">
              <GroupedComboBox.ItemTemplate>
                <DataTemplate DataType="vm:FoodItem">
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </GroupedComboBox.ItemTemplate>
            </GroupedComboBox>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Selected:" FontWeight="SemiBold" />
              <TextBlock Text="{Binding SelectedEmptyGroupItemWithName.Name, FallbackValue='(none)'}" />
            </StackPanel>
          </StackPanel>
          <TextBlock Grid.Column="2" Grid.Row="2" TextWrapping="Wrap" Foreground="{DynamicResource TextControlPlaceholderForeground}">
            Empty category gets a display header via EmptyGroupName and custom group foreground.
          </TextBlock>

          <TextBlock Grid.Column="0" Grid.Row="3" VerticalAlignment="Top" Margin="0 5 0 0">
            <Bold>Scrolling:</Bold>
          </TextBlock>
          <StackPanel Grid.Column="1" Grid.Row="3" Spacing="8">
            <GroupedComboBox ItemsSource="{Binding LargeItems}"
                             SelectedItem="{Binding SelectedLargeItem}"
                             PlaceholderText="Many items"
                             GroupBinding="{Binding Category}"
                             GroupOrderAlphabetical="True"
                             MaxDropDownHeight="200">
              <GroupedComboBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel />
                </ItemsPanelTemplate>
              </GroupedComboBox.ItemsPanel>
              <GroupedComboBox.ItemTemplate>
                <DataTemplate DataType="vm:FoodItem">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding Name}" />
                    <TextBlock Text="{Binding Category}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextControlPlaceholderForeground}" />
                  </StackPanel>
                </DataTemplate>
              </GroupedComboBox.ItemTemplate>
            </GroupedComboBox>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Selected:" FontWeight="SemiBold" />
              <TextBlock Text="{Binding SelectedLargeItem.Name, FallbackValue='(none)'}" />
            </StackPanel>
          </StackPanel>
          <TextBlock Grid.Column="2" Grid.Row="3" TextWrapping="Wrap" Foreground="{DynamicResource TextControlPlaceholderForeground}">
            150 items across 3 categories. Tests popup scrolling with group headers.
          </TextBlock>

          <TextBlock Grid.Column="0" Grid.Row="4" VerticalAlignment="Top" Margin="0 5 0 0">
            <Bold>HeaderTemplate:</Bold>
          </TextBlock>
          <StackPanel Grid.Column="1" Grid.Row="4" Spacing="8">
            <GroupedComboBox ItemsSource="{Binding GroupedItems}"
                             PlaceholderText="Custom headers"
                             GroupBinding="{Binding Category}"
                             GroupOrderSelector="{Binding CategoryGroupOrderSelector}"
                             GroupOrderAlphabetical="True"
                             HeaderMargin="2 8 8 4">
              <GroupedComboBox.HeaderTemplate>
                <DataTemplate>
                  <Border Background="{DynamicResource SystemControlForegroundAccentBrush}"
                          CornerRadius="3"
                          Padding="6 2"
                          HorizontalAlignment="Left">
                    <TextBlock Text="{Binding}"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="11" />
                  </Border>
                </DataTemplate>
              </GroupedComboBox.HeaderTemplate>
              <GroupedComboBox.ItemTemplate>
                <DataTemplate DataType="vm:FoodItem">
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </GroupedComboBox.ItemTemplate>
            </GroupedComboBox>
          </StackPanel>
          <TextBlock Grid.Column="2" Grid.Row="4" TextWrapping="Wrap" Foreground="{DynamicResource TextControlPlaceholderForeground}">
            HeaderTemplate customizes only group headers. Selectable rows still use ItemTemplate and theme ComboBoxItem chrome.
          </TextBlock>

          <TextBlock Grid.Column="0" Grid.Row="5" VerticalAlignment="Top" Margin="0 5 0 0">
            <Bold>Pure XAML:</Bold>
          </TextBlock>
          <StackPanel Grid.Column="1" Grid.Row="5" Spacing="8">
            <GroupedComboBox PlaceholderText="Choose target"
                             MaxDropDownHeight="220"
                             HeaderForeground="#0000FF"
                             HeaderMargin="4 8 8 4">
              <GroupedComboBox.HeaderTemplate>
                <DataTemplate DataType="system:String">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <Border Width="6" Height="6" CornerRadius="3" Background="{DynamicResource SystemControlForegroundAccentBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding}" FontWeight="Bold" />
                  </StackPanel>
                </DataTemplate>
              </GroupedComboBox.HeaderTemplate>
              <GroupedComboBoxHeaderItem Content="Servers" Foreground="Green" />
              <GroupedComboBoxItem>Production</GroupedComboBoxItem>
              <GroupedComboBoxItem>Staging</GroupedComboBoxItem>
              <GroupedComboBoxItem>Development</GroupedComboBoxItem>

              <GroupedComboBoxHeaderItem Content="Workstations" />
              <GroupedComboBoxItem>Design laptop</GroupedComboBoxItem>
              <GroupedComboBoxItem>Build agent</GroupedComboBoxItem>
              <GroupedComboBoxItem>QA desktop</GroupedComboBoxItem>
            </GroupedComboBox>
          </StackPanel>
          <TextBlock Grid.Column="2" Grid.Row="5" TextWrapping="Wrap" Foreground="{DynamicResource TextControlPlaceholderForeground}">
            Headers and selectable items declared directly in XAML. HeaderTemplate is inherited by inline header items too.
          </TextBlock>

          <TextBlock Grid.Column="0" Grid.Row="6" VerticalAlignment="Top" Margin="0 5 0 0">
            <Bold>Inner slots:</Bold>
          </TextBlock>
          <GroupedComboBox Grid.Column="1" Grid.Row="6"
                           ItemsSource="{Binding GroupedItems}"
                           PlaceholderText="Same ComboBox chrome"
                           GroupBinding="{Binding Category}"
                           GroupOrderAlphabetical="True">
            <GroupedComboBox.ItemTemplate>
              <DataTemplate DataType="vm:FoodItem">
                <TextBlock Text="{Binding Name}" />
              </DataTemplate>
            </GroupedComboBox.ItemTemplate>
            <ComboBoxContent.InnerLeftContent>
              <Border Width="16" Height="16" Background="Green" CornerRadius="8" VerticalAlignment="Center" />
            </ComboBoxContent.InnerLeftContent>
            <ComboBoxContent.InnerLeftOfDropDownArrowContent>
              <Border Width="16" Height="16" Background="Orange" CornerRadius="8" VerticalAlignment="Center" />
            </ComboBoxContent.InnerLeftOfDropDownArrowContent>
            <ComboBoxContent.InnerRightContent>
              <TextBlock Text="kg" Margin="2 0" VerticalAlignment="Center" />
            </ComboBoxContent.InnerRightContent>
          </GroupedComboBox>
          <TextBlock Grid.Column="2" Grid.Row="6" TextWrapping="Wrap" Foreground="{DynamicResource TextControlPlaceholderForeground}">
            Attached ComboBoxContent slots still work because the control keeps the normal ComboBox template.
          </TextBlock>
        </Grid>
      </Border>
      <Border Grid.Column="1" Padding="20" Background="{DynamicResource LayoutBackgroundLowBrush}" VerticalAlignment="Top">
        <StackPanel Spacing="16">
          <StackPanel Spacing="6">
            <TextBlock FontWeight="Bold" FontSize="16">Live tests</TextBlock>
            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextControlPlaceholderForeground}">
              Keep a dropdown open on the left, then edit these values to validate dynamic updates.
            </TextBlock>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="HeaderMargin" FontWeight="SemiBold" />
            <TextBox Text="{Binding HeaderMarginText}" PlaceholderText="4 6 8 4" />
            <TextBlock Text="Applied to the Named groups combo." TextWrapping="Wrap" Foreground="{DynamicResource TextControlPlaceholderForeground}" />
          </StackPanel>

          <Separator />

          <StackPanel Spacing="8">
            <TextBlock Text="Dynamic items" FontWeight="SemiBold" />
            <GroupedComboBox ItemsSource="{Binding DynamicItems}"
                             SelectedItem="{Binding SelectedDynamicItem}"
                             PlaceholderText="Edit this list live"
                             HeaderMargin="{Binding HeaderMargin}"
                             GroupBinding="{Binding Category}"
                             GroupOrderAlphabetical="True"
                             MaxDropDownHeight="260">
              <GroupedComboBox.ItemTemplate>
                <DataTemplate DataType="vm:DynamicFoodItem">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding Name}" />
                    <TextBlock Text="{Binding Category}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextControlPlaceholderForeground}" />
                  </StackPanel>
                </DataTemplate>
              </GroupedComboBox.ItemTemplate>
            </GroupedComboBox>
            <TextBlock Text="Selected:"
                       FontWeight="SemiBold" />
            <TextBlock Text="{Binding SelectedDynamicItem.Name, FallbackValue='(none)'}" />
          </StackPanel>

          <StackPanel Spacing="8">
            <TextBlock Text="Add" FontWeight="SemiBold" />
            <TextBox Text="{Binding NewItemName}" PlaceholderText="Name" />
            <TextBox Text="{Binding NewItemCategory}" PlaceholderText="Category" />
            <Button Content="Add item" Command="{Binding AddDynamicItemCommand}" />
          </StackPanel>

          <StackPanel Spacing="8">
            <TextBlock Text="Edit selected" FontWeight="SemiBold" />
            <TextBox Text="{Binding EditItemName}" PlaceholderText="Name" />
            <TextBox Text="{Binding EditItemCategory}" PlaceholderText="Category" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Apply edit" Command="{Binding ApplyDynamicItemEditCommand}" />
              <Button Content="Remove" Command="{Binding RemoveSelectedDynamicItemCommand}" />
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </Border>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
