<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:design="clr-namespace:Devolutions.AvaloniaTheme.Linux.Design">

  <Design.PreviewWith>
    <design:ThemePreviewer>
      <StackPanel Margin="10" Spacing="10">
        <SplitButton Content="Accent" Classes="accent">
          <SplitButton.Flyout>
            <MenuFlyout>
              <MenuItem Header="A" />
              <MenuItem Header="B" />
              <MenuItem Header="C" />
            </MenuFlyout>
          </SplitButton.Flyout>
        </SplitButton>
        <SplitButton Content="SplitButton">
          <SplitButton.Flyout>
            <Flyout>Hello</Flyout>
          </SplitButton.Flyout>
        </SplitButton>
        <SplitButton IsEnabled="False">Disabled</SplitButton>
      </StackPanel>
    </design:ThemePreviewer>
  </Design.PreviewWith>

  <x:Double x:Key="SplitButtonPrimaryButtonSize">26</x:Double>
  <x:Double x:Key="SplitButtonSecondaryButtonSize">22</x:Double>
  <x:Double x:Key="SplitButtonSeparatorWidth">1</x:Double>

  <ControlTheme x:Key="LinuxSplitButtonPartTheme" TargetType="Button">
    <Setter Property="MinHeight" Value="{DynamicResource InputDefaultHeight}" />
    <Setter Property="Background" Value="{DynamicResource ButtonBackground}" />
    <Setter Property="Foreground" Value="{WindowActiveResourceToggler ForegroundHighBrush, ForegroundInactiveBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}" />
    <Setter Property="BorderThickness" Value="{DynamicResource ButtonBorderThickness}" />
    <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
    <Setter Property="Padding" Value="{DynamicResource ButtonPadding}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="FocusAdorner" Value="{x:Null}" />
    <Setter Property="Template">
      <ControlTemplate>
        <Panel>
          <Border Name="BackgroundElement"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}" />
          <ContentPresenter Name="PART_ContentPresenter"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Foreground="{TemplateBinding Foreground}"
                            Padding="{TemplateBinding Padding}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                            FontSize="{TemplateBinding FontSize}"
                            FontWeight="{TemplateBinding FontWeight}" />
        </Panel>
      </ControlTemplate>
    </Setter>

    <Style Selector="^:pointerover /template/ Border#BackgroundElement">
      <Setter Property="Background" Value="{DynamicResource ButtonBackgroundHoverColor}" />
    </Style>

    <Style Selector="^:pressed /template/ Border#BackgroundElement">
      <Setter Property="Background" Value="{DynamicResource ButtonBackgroundPressed}" />
    </Style>

    <Style Selector="^.accent">
      <Setter Property="Foreground" Value="{WindowActiveResourceToggler AccentForegroundHighBrush, AccentForegroundInactiveBrush}" />
      <Style Selector="^ /template/ Border#BackgroundElement">
        <Setter Property="Background" Value="{DynamicResource SystemAccentColor}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
      </Style>

      <Style Selector="^:pointerover /template/ Border#BackgroundElement">
        <Setter Property="Background" Value="{DynamicResource AccentButtonBackgroundHover}" />
      </Style>
      <Style Selector="^:pressed">
        <Style Selector="^ /template/ Border#BackgroundElement">
          <Setter Property="Background" Value="{DynamicResource SystemAccentColorDark1}" />
        </Style>
      </Style>

    </Style>
  </ControlTheme>

  <ControlTheme x:Key="{x:Type SplitButton}" TargetType="SplitButton">
    <Setter Property="Background" Value="{DynamicResource ButtonBackground}" />
    <Setter Property="Foreground" Value="{WindowActiveResourceToggler ForegroundHighBrush, ForegroundInactiveBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}" />
    <Setter Property="BorderThickness" Value="{DynamicResource ButtonBorderThickness}" />
    <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
    <Setter Property="Padding" Value="{DynamicResource ButtonPadding}" />
    <Setter Property="MinHeight" Value="{DynamicResource InputDefaultHeight}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="FocusAdorner" Value="{x:Null}" />
    <Setter Property="Template">
      <ControlTemplate>
        <Panel>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
              x:Name="PART_PrimaryButton"
              Grid.Column="0"
              Classes="PrimaryButton"
              Classes.accent="{Binding Classes, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static DevoConverters.HasClass}, ConverterParameter=accent}"
              Theme="{StaticResource LinuxSplitButtonPartTheme}"
              MinWidth="{StaticResource SplitButtonPrimaryButtonSize}"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="1,1,0,1"
              CornerRadius="{TemplateBinding CornerRadius, Converter={x:Static DevoConverters.CornerRadiusExtractor}, ConverterParameter={x:Static CornerRadiusSubset.Left}}"
              Foreground="{TemplateBinding Foreground}"
              Content="{TemplateBinding Content}"
              ContentTemplate="{TemplateBinding ContentTemplate}"
              Command="{TemplateBinding Command}"
              CommandParameter="{TemplateBinding CommandParameter}"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
              Padding="{TemplateBinding Padding}"
              Focusable="False"
              KeyboardNavigation.IsTabStop="False" />

            <Rectangle
              x:Name="SeparatorLine"
              Grid.Column="1"
              HorizontalAlignment="Left"
              VerticalAlignment="Stretch"
              Width="{StaticResource SplitButtonSeparatorWidth}"
              Fill="{TemplateBinding BorderBrush}"
              IsHitTestVisible="False"
              ZIndex="1" />

            <Button
              x:Name="PART_SecondaryButton"
              Grid.Column="1"
              Classes="SecondaryButton"
              Classes.accent="{Binding Classes, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static DevoConverters.HasClass}, ConverterParameter=accent}"
              Theme="{StaticResource LinuxSplitButtonPartTheme}"
              MinWidth="{StaticResource SplitButtonSecondaryButtonSize}"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="0,1,1,1"
              CornerRadius="{TemplateBinding CornerRadius, Converter={x:Static DevoConverters.CornerRadiusExtractor}, ConverterParameter={x:Static CornerRadiusSubset.Right}}"
              Foreground="{TemplateBinding Foreground}"
              Padding="0"
              HorizontalContentAlignment="Center"
              VerticalContentAlignment="Center"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              Focusable="False"
              KeyboardNavigation.IsTabStop="False">
              <Path
                Name="DropDownGlyph"
                UseLayoutRounding="False"
                IsHitTestVisible="False"
                Height="6"
                Stretch="Uniform"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                Data="{DynamicResource ChevronPathThin}" />
            </Button>
          </Grid>
          <Border Name="FocusBorderElement"
                  IsVisible="False"
                  BorderBrush="{WindowActiveResourceToggler InputFocusedBorder, InputFocusedInactiveBorder}"
                  BorderThickness="{StaticResource FocusBorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}" />
        </Panel>
      </ControlTemplate>
    </Setter>

    <!-- Focus states -->
    <Style Selector="^:focus-visible /template/ Border#FocusBorderElement">
      <Setter Property="IsVisible" Value="True" />
    </Style>
    <Style Selector="^:focus /template/ Border#FocusBorderElement">
      <Setter Property="IsVisible" Value="True" />
    </Style>

    <Style Selector="^:flyout-open /template/ Button#PART_SecondaryButton">
      <Setter Property="Background" Value="{DynamicResource ButtonBackgroundPressed}" />
    </Style>

    <!-- Disabled -->
    <Style Selector="^:disabled">
      <Style Selector="^ /template/ Button#PART_PrimaryButton, ^ /template/ Button#PART_SecondaryButton">
        <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundDisabled}" />
        <Setter Property="Background" Value="{DynamicResource ButtonBackgroundDisabled}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderDisabled}" />
      </Style>
      <Style Selector="^ /template/ Rectangle#SeparatorLine">
        <Setter Property="Fill" Value="{DynamicResource ButtonBorderDisabled}" />
      </Style>
    </Style>

    <Style Selector="^.accent /template/ Rectangle#SeparatorLine">
      <Setter Property="Fill" Value="{WindowActiveResourceToggler AccentForegroundHighBrush, AccentForegroundInactiveBrush}" />
    </Style>
    <Style Selector="^.accent:flyout-open /template/ Button#PART_SecondaryButton">
      <Setter Property="Background" Value="{DynamicResource SystemAccentColorDark1}" />
    </Style>
  </ControlTheme>

</ResourceDictionary>