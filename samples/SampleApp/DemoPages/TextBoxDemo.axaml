<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SampleApp.ViewModels"
             xmlns:ext="clr-namespace:SampleApp.MarkupExtensions"
             xmlns:devex="clr-namespace:Devolutions.AvaloniaTheme.DevExpress.Controls;assembly=Devolutions.AvaloniaTheme.DevExpress"
             xmlns:macos="clr-namespace:Devolutions.AvaloniaTheme.MacOS.Controls;assembly=Devolutions.AvaloniaTheme.MacOS"
             xmlns:linux="clr-namespace:Devolutions.AvaloniaTheme.Linux.Controls;assembly=Devolutions.AvaloniaTheme.Linux"
             x:DataType="vm:TextBoxViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="700"
             x:Class="SampleApp.DemoPages.TextBoxDemo">

  <StackPanel>
    <StackPanel Orientation="Horizontal" Spacing="10" Margin="20 20 20 0">
      <TextBlock VerticalAlignment="Center">For automatic focus test:</TextBlock>
      <TextBox Width="200" CaretBrush="Transparent" />
    </StackPanel>
    <ScrollViewer>
      <Border Margin="20"
              BorderBrush="{DynamicResource LayoutBorderMidBrush}"
              BorderThickness="{DynamicResource BorderThickness}"
              CornerRadius="{DynamicResource LayoutCornerRadius}"
              Background="{DynamicResource LayoutBackgroundLowBrush}">
        <StackPanel Margin="20" Spacing="10" HorizontalAlignment="Left" Orientation="Horizontal">
          <StackPanel Margin="20" Width="300" Spacing="10" HorizontalAlignment="Left">
            <Label>_Name:</Label>
            <TextBox Watermark="Enter your name" />
            <Label>Password:</Label>
            <TextBox PasswordChar="*" Watermark="Enter your password" />
            <Label>Notes:</Label>
            <TextBox Height="100" AcceptsReturn="True" TextWrapping="Wrap"
                     Text="Create powerful dashboards, orchestrate tasks, and streamline administrative workflows — all from a unified, secure, and flexible automation platform. Automate with confidence. Design and run PowerShell scripts, scheduled jobs, and workflows. Build secure dashboards and portals with PowerShell. Create interactive dashboards, forms, and administrative portals." />
            <TextBox Height="100" AcceptsReturn="True" TextWrapping="Wrap"
                     Watermark="More Notes ..." />
            <TextBox InnerLeftContent="http://" />
            <TextBox InnerRightContent=".com" />
            <TextBox
              InnerLeftContent="http://"
              InnerRightContent=".com" />
            <TextBox Classes="clearButton">With 'Clear' button</TextBox>
            <TextBox Watermark="Disabled with Watermark" IsEnabled="False" />
            <TextBox IsEnabled="False">Disabled Filled</TextBox>
            <TextBox PasswordChar="*" Classes="revealPasswordButton">Reveal Password</TextBox>
            <TextBox PasswordChar="*" Classes="revealPasswordButton" RevealPassword="True">Password Revealed</TextBox>
          </StackPanel>
          <StackPanel Margin="20" Width="300" Spacing="10" HorizontalAlignment="Left">
            <Label>Custom Height:</Label>
            <Grid ColumnDefinitions="*, Auto" HorizontalAlignment="Stretch">
              <TextBox Grid.Column="0" Watermark="Type here" Height="35" VerticalContentAlignment="Center" />
              <Button Grid.Column="1" Content="..." HorizontalContentAlignment="Center" Height="35" Width="35"
                      Margin="5 0 0 0 " />
            </Grid>
            <Label>Read Only:</Label>
            <TextBox IsReadOnly="True" Text="This is read-only text" />

            <Label>Error Indicator:</Label>
            <TextBox Watermark="Required Input" Text="{Binding RequiredInput}" />

            <TextBox Height="22" MinHeight="22" MaxHeight="22"
                     IsVisible="{ext:ThemeIsOneOf 'DevExpress'}">
              thin
            </TextBox>

            <TextBlock Margin="0 10 0 0">
              <Bold>For embeded TextBoxes use</Bold><LineBreak />
              <TextBlock Classes="code">borderless</TextBlock> /
              <TextBlock Classes="code">no-focus-border</TextBlock>:
            </TextBlock>
            <TextBox Watermark="Enter your name" Classes="no-focus-border">no focus</TextBox>
            <TextBox Watermark="Enter your name" Classes="borderless">borderless</TextBox>
            <TextBox Watermark="Enter your name" Classes="borderless no-focus-border">Borderless and no focus</TextBox>
            <TextBox Watermark="Enter your name" Classes="borderless" IsEnabled="False">Disabled Borderless</TextBox>

            <TextBox Watermark="Inner left and right">
              <TextBox.InnerLeftContent>
                <Border Width="12" Height="12" Background="Green" />
              </TextBox.InnerLeftContent>
              <TextBox.InnerRightContent>
                <Border Width="12" Height="12" Background="Blue" />
              </TextBox.InnerRightContent>
            </TextBox>

          </StackPanel>

          <!-- Third column: open context menus for visual regression testing.
               Uses MenuFlyoutPresenter (same visual as the real flyout) with the actual theme
               string resources, SVG assets, and platform-aware gestures — so only item
               structure needs to be kept in sync, not content. One column per theme so each
               references its own assembly's SVG assets and command/gesture statics. -->
          <StackPanel Margin="20" Spacing="30" HorizontalAlignment="Left"
                      IsVisible="{ext:ThemeIsOneOf 'DevExpress'}">
            <TextBlock FontWeight="SemiBold">Context Menu (enabled)</TextBlock>
            <MenuFlyoutPresenter>
              <MenuItem Header="{DynamicResource StringTextFlyoutUndoText}"
                        InputGesture="{x:Static devex:TextBoxContextMenuCommands.UndoGesture}">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.DevExpress/Accents/Assets/Undo.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <Separator />
              <MenuItem Header="{DynamicResource StringTextFlyoutCutText}"
                        InputGesture="{x:Static TextBox.CutGesture}">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.DevExpress/Accents/Assets/Cut.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="{DynamicResource StringTextFlyoutCopyText}"
                        InputGesture="{x:Static TextBox.CopyGesture}">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.DevExpress/Accents/Assets/Copy.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="{DynamicResource StringTextFlyoutPasteText}"
                        InputGesture="{x:Static TextBox.PasteGesture}">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.DevExpress/Accents/Assets/Paste.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="{DynamicResource StringTextFlyoutDeleteText}">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.DevExpress/Accents/Assets/Delete.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <Separator />
              <MenuItem Header="{DynamicResource StringTextFlyoutSelectAllText}"
                        InputGesture="{x:Static devex:TextBoxContextMenuCommands.SelectAllGesture}" />
            </MenuFlyoutPresenter>

            <TextBlock FontWeight="SemiBold">Context Menu (disabled)</TextBlock>
            <MenuFlyoutPresenter>
              <MenuItem Header="{DynamicResource StringTextFlyoutUndoText}"
                        InputGesture="{x:Static devex:TextBoxContextMenuCommands.UndoGesture}"
                        IsEnabled="False">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.DevExpress/Accents/Assets/Undo.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <Separator />
              <MenuItem Header="{DynamicResource StringTextFlyoutCutText}"
                        InputGesture="{x:Static TextBox.CutGesture}"
                        IsEnabled="False">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.DevExpress/Accents/Assets/Cut.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="{DynamicResource StringTextFlyoutCopyText}"
                        InputGesture="{x:Static TextBox.CopyGesture}"
                        IsEnabled="False">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.DevExpress/Accents/Assets/Copy.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="{DynamicResource StringTextFlyoutPasteText}"
                        InputGesture="{x:Static TextBox.PasteGesture}"
                        IsEnabled="False">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.DevExpress/Accents/Assets/Paste.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="{DynamicResource StringTextFlyoutDeleteText}" IsEnabled="False">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.DevExpress/Accents/Assets/Delete.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <Separator />
              <MenuItem Header="{DynamicResource StringTextFlyoutSelectAllText}"
                        InputGesture="{x:Static devex:TextBoxContextMenuCommands.SelectAllGesture}"
                        IsEnabled="False" />
            </MenuFlyoutPresenter>
          </StackPanel>

          <StackPanel Margin="20" Spacing="30" HorizontalAlignment="Left"
                      IsVisible="{ext:ThemeIsOneOf 'MacClassic, LiquidGlass'}">
            <TextBlock FontWeight="SemiBold">Context Menu (enabled)</TextBlock>
            <MenuFlyoutPresenter>
              <MenuItem Header="{DynamicResource StringTextFlyoutUndoText}"
                        InputGesture="{x:Static macos:TextBoxContextMenuCommands.UndoGesture}">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.MacOS/Accents/Assets/Undo.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <Separator />
              <MenuItem Header="{DynamicResource StringTextFlyoutCutText}"
                        InputGesture="{x:Static TextBox.CutGesture}">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.MacOS/Accents/Assets/Cut.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="{DynamicResource StringTextFlyoutCopyText}"
                        InputGesture="{x:Static TextBox.CopyGesture}">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.MacOS/Accents/Assets/Copy.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="{DynamicResource StringTextFlyoutPasteText}"
                        InputGesture="{x:Static TextBox.PasteGesture}">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.MacOS/Accents/Assets/Paste.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="{DynamicResource StringTextFlyoutDeleteText}">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.MacOS/Accents/Assets/Delete.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <Separator />
              <MenuItem Header="{DynamicResource StringTextFlyoutSelectAllText}"
                        InputGesture="{x:Static macos:TextBoxContextMenuCommands.SelectAllGesture}" />
            </MenuFlyoutPresenter>

            <TextBlock FontWeight="SemiBold">Context Menu (disabled)</TextBlock>
            <MenuFlyoutPresenter>
              <MenuItem Header="{DynamicResource StringTextFlyoutUndoText}"
                        InputGesture="{x:Static macos:TextBoxContextMenuCommands.UndoGesture}"
                        IsEnabled="False">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.MacOS/Accents/Assets/Undo.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <Separator />
              <MenuItem Header="{DynamicResource StringTextFlyoutCutText}"
                        InputGesture="{x:Static TextBox.CutGesture}"
                        IsEnabled="False">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.MacOS/Accents/Assets/Cut.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="{DynamicResource StringTextFlyoutCopyText}"
                        InputGesture="{x:Static TextBox.CopyGesture}"
                        IsEnabled="False">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.MacOS/Accents/Assets/Copy.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="{DynamicResource StringTextFlyoutPasteText}"
                        InputGesture="{x:Static TextBox.PasteGesture}"
                        IsEnabled="False">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.MacOS/Accents/Assets/Paste.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="{DynamicResource StringTextFlyoutDeleteText}" IsEnabled="False">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.MacOS/Accents/Assets/Delete.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <Separator />
              <MenuItem Header="{DynamicResource StringTextFlyoutSelectAllText}"
                        InputGesture="{x:Static macos:TextBoxContextMenuCommands.SelectAllGesture}"
                        IsEnabled="False" />
            </MenuFlyoutPresenter>
          </StackPanel>

          <StackPanel Margin="20" Spacing="30" HorizontalAlignment="Left"
                      IsVisible="{ext:ThemeIsOneOf 'Linux'}">
            <TextBlock FontWeight="SemiBold">Context Menu (enabled)</TextBlock>
            <MenuFlyoutPresenter>
              <MenuItem Header="{DynamicResource StringTextFlyoutUndoText}"
                        InputGesture="{x:Static linux:TextBoxContextMenuCommands.UndoGesture}">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.Linux/Accents/Assets/Undo.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <Separator />
              <MenuItem Header="{DynamicResource StringTextFlyoutCutText}"
                        InputGesture="{x:Static TextBox.CutGesture}">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.Linux/Accents/Assets/Cut.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="{DynamicResource StringTextFlyoutCopyText}"
                        InputGesture="{x:Static TextBox.CopyGesture}">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.Linux/Accents/Assets/Copy.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="{DynamicResource StringTextFlyoutPasteText}"
                        InputGesture="{x:Static TextBox.PasteGesture}">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.Linux/Accents/Assets/Paste.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="{DynamicResource StringTextFlyoutDeleteText}">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.Linux/Accents/Assets/Delete.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <Separator />
              <MenuItem Header="{DynamicResource StringTextFlyoutSelectAllText}"
                        InputGesture="{x:Static linux:TextBoxContextMenuCommands.SelectAllGesture}" />
            </MenuFlyoutPresenter>

            <TextBlock FontWeight="SemiBold">Context Menu (disabled)</TextBlock>
            <MenuFlyoutPresenter>
              <MenuItem Header="{DynamicResource StringTextFlyoutUndoText}"
                        InputGesture="{x:Static linux:TextBoxContextMenuCommands.UndoGesture}"
                        IsEnabled="False">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.Linux/Accents/Assets/Undo.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <Separator />
              <MenuItem Header="{DynamicResource StringTextFlyoutCutText}"
                        InputGesture="{x:Static TextBox.CutGesture}"
                        IsEnabled="False">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.Linux/Accents/Assets/Cut.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="{DynamicResource StringTextFlyoutCopyText}"
                        InputGesture="{x:Static TextBox.CopyGesture}"
                        IsEnabled="False">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.Linux/Accents/Assets/Copy.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="{DynamicResource StringTextFlyoutPasteText}"
                        InputGesture="{x:Static TextBox.PasteGesture}"
                        IsEnabled="False">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.Linux/Accents/Assets/Paste.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="{DynamicResource StringTextFlyoutDeleteText}" IsEnabled="False">
                <MenuItem.Icon>
                  <Svg Path="avares://Devolutions.AvaloniaTheme.Linux/Accents/Assets/Delete.svg" />
                </MenuItem.Icon>
              </MenuItem>
              <Separator />
              <MenuItem Header="{DynamicResource StringTextFlyoutSelectAllText}"
                        InputGesture="{x:Static linux:TextBoxContextMenuCommands.SelectAllGesture}"
                        IsEnabled="False" />
            </MenuFlyoutPresenter>
          </StackPanel>

        </StackPanel>
      </Border>
    </ScrollViewer>
  </StackPanel>

</UserControl>